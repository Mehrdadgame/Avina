    <base href="/" />
    <title>آخرین نگهبان</title>

    <ResourcePreloader />

    <!-- Bootstrap -->
    <link rel="stylesheet" href="lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Tailwind Config (Material 3 dark tokens) -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        background: "#10131a",
                        "on-background": "#e0e2ec",
                        "on-surface-variant": "#c1c6d5",
                        "on-primary": "#002f64",
                        "surface-container-highest": "#32353c",
                        "primary-container": "#4090fe",
                        "surface-container": "#1c2026",
                        "surface-container-low": "#181c22",
                        "on-secondary": "#153058",
                        primary: "#aac7ff",
                        tertiary: "#ffb68c",
                        "surface-variant": "#32353c",
                        secondary: "#afc7f7",
                        "tertiary-container": "#e3711f",
                        "error-container": "#93000a",
                        surface: "#10131a",
                        "secondary-container": "#2e4770",
                        "outline-variant": "#414753",
                        "on-tertiary-container": "#481d00",
                        outline: "#8b919f",
                        "on-surface": "#e0e2ec",
                        "surface-container-lowest": "#0b0e15",
                        "surface-container-high": "#272a31",
                        "on-secondary-container": "#9db6e5",
                        "tertiary-fixed": "#ffdbc9",
                        "secondary-fixed": "#d6e3ff",
                        "on-tertiary": "#532200",
                        error: "#ffb4ab",
                    }
                }
            }
        };
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <!-- App CSS files -->
    <link rel="stylesheet" href="css/app-custom.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="@Assets["Avina.styles.css"]" />
    <link rel="stylesheet" href="css/school.css" />
    <link rel="stylesheet" href="css/games.css" />
    <link rel="stylesheet" href="css/store.css" />
    <link rel="stylesheet" href="css/profile.css" />
    <link rel="stylesheet" href="css/upload.css" />
    <link rel="stylesheet" href="css/home.css" />
    <link rel="stylesheet" href="css/responsive-components.css" />
    <link rel="stylesheet" href="css/stars-bg.css" />

