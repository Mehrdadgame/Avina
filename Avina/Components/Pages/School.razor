@page "/school"
@using Avina.Models
@using Avina.Services
@inject ICourseService CourseService
@rendermode InteractiveServer

<div class="max-w-5xl mx-auto px-5 md:px-10 pt-6 pb-10">

    <!-- Podcast Banner -->
    <section class="mb-10 animate-page">
        <div class="podcast-banner rounded-2xl p-7 md:p-10 flex flex-col md:flex-row items-center justify-between gap-6 relative overflow-hidden">
            <div class="z-10 text-right space-y-3 max-w-lg">
                <span class="bg-secondary text-on-secondary px-3 py-1 rounded-full text-xs font-bold">جدیدترین انتشار</span>
                <h2 class="text-2xl md:text-3xl font-black text-white">پادکست «آخرین نگهبان»: هنر تفکر انتقادی</h2>
                <p class="text-white/80 leading-relaxed text-sm">در این قسمت با آریا همراه شوید تا بیاموزیم چگونه در دنیای اطلاعات، حقیقت را از شایعه تشخیص دهیم.</p>
                <button class="bg-white text-[#4248d4] px-6 py-2.5 rounded-xl font-bold flex items-center gap-2 hover:scale-105 active:scale-95 transition-all duration-200 w-fit">
                    <span>گوش دادن به اپیزود</span>
                    <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">play_circle</span>
                </button>
            </div>
            <div class="relative flex-shrink-0">
                <div class="absolute inset-0 bg-white/10 blur-3xl scale-150 rounded-full"></div>
                <div class="w-36 h-36 md:w-44 md:h-44 bg-white/20 rounded-full flex items-center justify-center relative z-10 backdrop-blur-sm">
                    <span class="material-symbols-outlined text-white text-7xl" style="font-variation-settings:'FILL' 1;">headphones</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Category Chips -->
    <section class="mb-8 overflow-x-auto hide-scrollbar animate-page delay-1">
        <div class="flex gap-3 pb-2">
            <button class="@GetChipClass("")  whitespace-nowrap px-5 py-2 rounded-xl text-sm transition-all" @onclick='() => SetCategory("")'>همه دوره‌ها</button>
            <button class="@GetChipClass("ریاضی") whitespace-nowrap px-5 py-2 rounded-xl text-sm transition-all" @onclick='() => SetCategory("ریاضی")'>دروس مدرسه‌ای</button>
            <button class="@GetChipClass("مهارت‌ها") whitespace-nowrap px-5 py-2 rounded-xl text-sm transition-all" @onclick='() => SetCategory("مهارت‌ها")'>مهارت‌های زندگی</button>
            <button class="@GetChipClass("علوم") whitespace-nowrap px-5 py-2 rounded-xl text-sm transition-all" @onclick='() => SetCategory("علوم")'>علوم</button>
            <button class="@GetChipClass("برنامه‌نویسی") whitespace-nowrap px-5 py-2 rounded-xl text-sm transition-all" @onclick='() => SetCategory("برنامه‌نویسی")'>برنامه‌نویسی</button>
        </div>
    </section>

    <!-- My Courses (enrolled) -->
    <section class="mb-10 animate-page delay-2">
        <div class="flex justify-between items-center mb-5">
            <h3 class="text-xl font-black">دوره‌های من</h3>
            <a href="#" class="text-primary text-sm font-bold flex items-center gap-1 hover:underline">مشاهده همه</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            @foreach (var (course, index) in enrolledCourses.Select((c, i) => (c, i)))
            {
                <div class="bg-surface-container-lowest p-5 rounded-2xl flex items-center gap-5 shadow-sm card-lift relative">
                    <div class="w-20 h-20 rounded-xl overflow-hidden flex-shrink-0 bg-surface-container-high">
                        <img src="https://images.unsplash.com/photo-1635070041078-e363dbe005cb?w=200&q=80" alt="@course.Title" class="w-full h-full object-cover" />
                    </div>
                    <div class="flex-1 text-right">
                        <h4 class="font-bold text-base mb-1">@course.Title</h4>
                        <div class="flex justify-between text-xs text-on-surface-variant mb-2">
                            <span>@(index == 0 ? "۶۸٪ تکمیل شده" : "۳۲٪ تکمیل شده")</span>
                            <span>@course.Instructor</span>
                        </div>
                        <div class="h-2.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="h-full primary-gradient rounded-full progress-bar"
                                 style="width:@(index == 0 ? "68%" : "32%"); animation-delay:@(index == 0 ? "0.3s" : "0.5s");"></div>
                        </div>
                    </div>
                    @if (index == 0)
                    {
                        <span class="absolute -top-2.5 -right-2.5 bg-tertiary-container text-on-tertiary-container text-[10px] px-2 py-0.5 rounded-full font-black border-2 border-background shadow">ادامه نبرد</span>
                    }
                </div>
            }
        </div>
    </section>

    <!-- Course Grid -->
    <section class="animate-page delay-3">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-black">کاوش در علوم</h3>
            <div class="bg-surface-container-low px-3 py-1.5 rounded-full flex items-center gap-2">
                <span class="material-symbols-outlined text-on-surface-variant text-lg">search</span>
                <input type="text"
                       class="bg-transparent border-none focus:outline-none text-sm w-32 text-right text-on-surface placeholder-on-surface-variant"
                       placeholder="جستجو..."
                       @oninput="OnSearch" />
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var course in filteredCourses)
            {
                <div class="course-card group flex flex-col bg-surface-container-low rounded-2xl overflow-hidden card-lift cursor-pointer"
                     @onclick="() => EnrollCourse(course.Id)">
                    <div class="h-44 relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1614741118887-7a4ee193a5fa?w=400&q=80"
                             alt="@course.Title" class="course-img w-full h-full object-cover" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                        <div class="absolute bottom-3 right-3 flex gap-1.5">
                            <span class="bg-white/20 backdrop-blur-md text-white text-[10px] px-2 py-0.5 rounded-lg">@course.Category</span>
                            <span class="bg-white/20 backdrop-blur-md text-white text-[10px] px-2 py-0.5 rounded-lg">سطح متوسط</span>
                        </div>
                    </div>
                    <div class="p-5 text-right flex-1 flex flex-col">
                        <h4 class="text-base font-bold mb-2">@course.Title</h4>
                        <p class="text-xs text-on-surface-variant mb-4 leading-relaxed line-clamp-2 flex-1">@course.Description</p>
                        <div class="flex justify-between items-center">
                            <div class="flex items-center gap-1 text-tertiary font-bold">
                                <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">grade</span>
                                <span class="text-xs">@course.Rating.ToString("F1")</span>
                            </div>
                            <button class="text-primary font-black text-xs hover:underline">مشاهده سرفصل‌ها</button>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!filteredCourses.Any())
        {
            <div class="text-center py-16 text-on-surface-variant">
                <span class="material-symbols-outlined text-5xl mb-3 block">search_off</span>
                <p class="font-bold">دوره‌ای با این مشخصات یافت نشد.</p>
            </div>
        }
    </section>
</div>

@code {
    private List<Course> allCourses = new();
    private List<Course> filteredCourses = new();
    private List<Course> enrolledCourses = new();
    private string searchTerm = "";
    private string selectedCategory = "";

    protected override async Task OnInitializedAsync()
    {
        allCourses = await CourseService.GetAllCoursesAsync();
        enrolledCourses = await CourseService.GetEnrolledCoursesAsync(1);
        filteredCourses = allCourses;
    }

    private string GetChipClass(string category)
        => selectedCategory == category
            ? "chip-active"
            : "bg-surface-container-low text-on-surface hover:bg-surface-container-high";

    private void SetCategory(string category)
    {
        selectedCategory = category;
        ApplyFilters();
    }

    private void OnSearch(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        filteredCourses = allCourses
            .Where(c => string.IsNullOrEmpty(searchTerm) || (c.Title ?? "").Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            .Where(c => string.IsNullOrEmpty(selectedCategory) || c.Category == selectedCategory)
            .ToList();
    }

    private void EnrollCourse(int courseId)
    {
        Console.WriteLine($"ثبت‌نام در دوره {courseId}");
    }
}
