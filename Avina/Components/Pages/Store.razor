@page "/store"
@using Avina.Models
@rendermode InteractiveServer

<div class="px-4 md:px-8 pt-6 pb-28 max-w-7xl">

    <!-- Hero Banner -->
    <section class="mb-10 animate-page">
        <div class="hero-banner relative overflow-hidden rounded-2xl h-64 md:h-80 flex items-center">
            <div class="absolute inset-0 bg-black/10"></div>
            <div class="relative z-10 p-7 md:p-14 max-w-xl text-white">
                <span class="bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full text-xs font-bold mb-3 inline-block">کیت جدید</span>
                <h1 class="text-3xl md:text-5xl font-black mb-3 leading-tight">کیت خلاقیت:<br />نگهبانان کهن</h1>
                <p class="text-base opacity-85 mb-6 leading-relaxed">با این مجموعه، ابزارهای جادویی خود را بسازید و به نبرد با تاریکی بروید.</p>
                <button class="bg-white text-[#4248d4] px-7 py-3 rounded-xl font-bold text-base hover:scale-105 active:scale-95 transition-transform duration-200 shadow-lg">همین حالا دریافت کنید</button>
            </div>
            <div class="absolute left-0 bottom-0 top-0 w-2/5 hidden md:block overflow-hidden opacity-30">
                <div class="w-full h-full bg-white/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-white text-[160px]" style="font-variation-settings:'FILL' 1;">auto_awesome</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Categories & QR Hub -->
    <section class="grid grid-cols-1 md:grid-cols-12 gap-5 mb-10 animate-page delay-1">
        <div class="md:col-span-4 bg-tertiary-container rounded-2xl p-7 flex flex-col justify-between relative overflow-hidden cursor-pointer active:scale-95 transition-transform card-lift">
            <div class="relative z-10">
                <span class="material-symbols-outlined text-4xl mb-4 text-on-tertiary-container" style="font-variation-settings:'FILL' 1;">qr_code_scanner</span>
                <h3 class="text-xl font-bold text-on-tertiary-container mb-2">اسکنر محصولات</h3>
                <p class="text-on-tertiary-container/80 text-sm leading-relaxed">کد کتاب‌های فیزیکی را اسکن کنید تا محتوای دیجیتال آن‌ها باز شود.</p>
            </div>
            <div class="absolute -bottom-3 -left-3 opacity-15 pointer-events-none">
                <span class="material-symbols-outlined text-[100px]">photo_camera</span>
            </div>
        </div>

        <div class="md:col-span-8 bg-surface-container-low rounded-2xl p-7">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-black">دسته‌بندی‌های برتر</h2>
                <button class="text-primary font-bold text-sm hover:underline">مشاهده همه</button>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div class="bg-surface-container-lowest p-5 rounded-xl flex items-center justify-between hover:bg-white dark:hover:bg-slate-800 transition-all shadow-sm group card-lift">
                    <div class="flex items-center gap-3">
                        <div class="bg-primary/10 p-2.5 rounded-xl text-primary group-hover:bg-primary group-hover:text-white transition-colors">
                            <span class="material-symbols-outlined">menu_book</span>
                        </div>
                        <div>
                            <h4 class="font-bold text-sm">کتاب و بازی</h4>
                            <p class="text-xs text-on-surface-variant">محصولات فیزیکی</p>
                        </div>
                    </div>
                    <span class="material-symbols-outlined text-outline-variant">chevron_left</span>
                </div>
                <div class="bg-surface-container-lowest p-5 rounded-xl flex items-center justify-between hover:bg-white dark:hover:bg-slate-800 transition-all shadow-sm group card-lift">
                    <div class="flex items-center gap-3">
                        <div class="bg-secondary/10 p-2.5 rounded-xl text-secondary group-hover:bg-secondary group-hover:text-white transition-colors">
                            <span class="material-symbols-outlined">smart_display</span>
                        </div>
                        <div>
                            <h4 class="font-bold text-sm">دوره‌های دیجیتال</h4>
                            <p class="text-xs text-on-surface-variant">آموزش آنلاین</p>
                        </div>
                    </div>
                    <span class="material-symbols-outlined text-outline-variant">chevron_left</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Product Grid -->
    <section class="mb-12 animate-page delay-2">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-black">جدیدترین محصولات</h2>
            <div class="flex gap-2 items-center">
                <div class="flex bg-surface-container p-1 rounded-full">
                    <button class="@GetFilterClass("all") px-4 py-1 rounded-full text-sm transition-all" @onclick='() => SetFilter("all")'>همه</button>
                    <button class="@GetFilterClass("physical") px-4 py-1 rounded-full text-sm font-medium text-on-surface-variant hover:text-on-surface transition-all" @onclick='() => SetFilter("physical")'>فیزیکی</button>
                    <button class="@GetFilterClass("digital") px-4 py-1 rounded-full text-sm font-medium text-on-surface-variant hover:text-on-surface transition-all" @onclick='() => SetFilter("digital")'>دیجیتال</button>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @foreach (var product in visibleProducts)
            {
                <div class="product-card group bg-surface-container-lowest rounded-2xl p-4 card-lift">
                    <div class="aspect-[3/4] rounded-xl overflow-hidden mb-4 relative">
                        <div class="product-img w-full h-full bg-gradient-to-br from-surface-container to-surface-container-high flex items-center justify-center">
                            <span class="material-symbols-outlined text-6xl text-outline-variant" style="font-variation-settings:'FILL' 1;">@GetProductIcon(product.Category)</span>
                        </div>
                        <div class="absolute top-2.5 right-2.5 bg-white/90 backdrop-blur-sm px-2.5 py-0.5 rounded-full flex items-center gap-1">
                            <span class="text-sm font-black text-on-surface">@product.CoinPrice.ToString("N0")</span>
                            <span class="material-symbols-outlined text-yellow-400 text-base" style="font-variation-settings:'FILL' 1;">monetization_on</span>
                        </div>
                        @if (product.IsNew)
                        {
                            <div class="absolute bottom-2.5 right-2.5 bg-secondary text-white text-[10px] font-bold px-2 py-0.5 rounded-lg">جدید</div>
                        }
                    </div>
                    <h3 class="font-bold text-base mb-0.5 px-1">@product.Name</h3>
                    <p class="text-on-surface-variant text-xs mb-4 px-1">@product.Description</p>
                    <button class="buy-btn w-full py-2.5 font-bold rounded-xl flex items-center justify-center gap-2 text-on-surface text-sm"
                            @onclick="() => AddToCart(product.Id)">
                        <span>خرید محصول</span>
                        <span class="material-symbols-outlined text-lg">shopping_cart</span>
                    </button>
                </div>
            }
        </div>
    </section>

    <!-- Info Section -->
    <section class="mt-10 p-8 md:p-12 bg-surface-container-lowest rounded-2xl shadow-sm animate-page delay-3">
        <div class="grid md:grid-cols-2 gap-10 items-center">
            <div class="order-2 md:order-1 text-right">
                <h2 class="text-2xl md:text-3xl font-black mb-4 text-on-background">تجربه یادگیری فراتر از فیزیک</h2>
                <p class="text-on-surface-variant leading-relaxed mb-6 text-sm">
                    هر محصول فیزیکی که از فروشگاه ما تهیه می‌کنید، یک کلید برای دنیای دیجیتال است.
                    با اسکن کدهای مخفی داخل بسته‌ها، مراحل جدید در بازی باز شده و سکه‌های جایزه دریافت خواهید کرد.
                </p>
                <div class="space-y-4">
                    <div class="flex items-center gap-3">
                        <div class="w-11 h-11 bg-tertiary-container rounded-full flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-on-tertiary-container">verified</span>
                        </div>
                        <span class="font-bold text-sm">تایید اصالت کالا</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-11 h-11 bg-secondary-container rounded-full flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-on-secondary-container">sync</span>
                        </div>
                        <span class="font-bold text-sm">همگام‌سازی با اپلیکیشن</span>
                    </div>
                </div>
            </div>
            <div class="order-1 md:order-2 flex justify-center">
                <div class="w-full max-w-xs aspect-square bg-gradient-to-tr from-surface-container to-surface-container-high rounded-3xl p-6 relative">
                    <div class="absolute inset-4 bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-4 flex flex-col justify-center items-center text-center">
                        <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mb-3">
                            <span class="material-symbols-outlined text-4xl text-primary" style="font-variation-settings:'FILL' 1;">token</span>
                        </div>
                        <h4 class="text-lg font-bold mb-1">امتیاز پاداش</h4>
                        <p class="text-xs text-on-surface-variant">با هر خرید سکه رایگان دریافت کنید و سطح خود را بالا ببرید.</p>
                    </div>
                    <div class="badge-rotate absolute -top-5 -right-5 bg-secondary text-white px-5 py-2 rounded-2xl shadow-lg font-black text-sm">هدیه ویژه</div>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- Cart FAB -->
@if (cartCount > 0)
{
    <div class="fixed bottom-20 left-5 z-40 md:left-10 md:bottom-10">
        <button class="fab-pulse primary-gradient text-white w-14 h-14 rounded-full shadow-2xl flex items-center justify-center active:scale-90 transition-transform relative">
            <span class="material-symbols-outlined text-2xl">shopping_cart</span>
            <span class="absolute -top-1 -right-1 bg-error-container text-white text-[10px] font-bold w-5 h-5 rounded-full flex items-center justify-center">@cartCount</span>
        </button>
    </div>
}

@code {
    private string activeFilter = "all";
    private int cartCount = 0;

    private List<Product> allProducts = new();

    private List<Product> visibleProducts => activeFilter switch
    {
        "physical" => allProducts.Where(p => p.CoinPrice <= 1000).ToList(),
        "digital"  => allProducts.Where(p => p.CoinPrice > 1000).ToList(),
        _          => allProducts
    };

    protected override void OnInitialized()
    {
        allProducts = new List<Product>
        {
            new Product { Id = 1, Name = "آخرین نگهبان: طلوع", Description = "نویسنده: علیرضا پارسا", CoinPrice = 450,  Category = "کتاب‌ها",          IsNew = false, Price = 120000, Stock = 20 },
            new Product { Id = 2, Name = "دوره جامع پایتون",   Description = "مدرس: سارا احمدی",  CoinPrice = 1200, Category = "دوره‌های ویدیویی",    IsNew = true,  Price = 350000, Stock = 999 },
            new Product { Id = 3, Name = "بازی رومیزی: فتح دژ", Description = "تعداد بازیکن: ۲-۴ نفر", CoinPrice = 890, Category = "بازی‌های فکری", IsNew = false, Price = 180000, Stock = 15 },
            new Product { Id = 4, Name = "افسانه‌های شاهنامه", Description = "مناسب سنین ۷ تا ۱۲ سال", CoinPrice = 300, Category = "کتاب‌ها",          IsNew = true,  Price = 85000,  Stock = 30 },
            new Product { Id = 5, Name = "کیت خلاقیت نگهبانان", Description = "ابزارهای ساخت و خلاقیت", CoinPrice = 1250, Category = "کیت‌های آموزشی", IsNew = true, Price = 250000, Stock = 10 },
            new Product { Id = 6, Name = "دسترسی ویژه دوره‌ها", Description = "تمام دوره‌های پرمیوم",  CoinPrice = 2250, Category = "دوره‌های ویدیویی", IsNew = false, Price = 450000, Stock = 999 },
        };
    }

    private string GetFilterClass(string filter)
        => activeFilter == filter ? "filter-active" : "text-on-surface-variant";

    private void SetFilter(string filter)
    {
        activeFilter = filter;
    }

    private void AddToCart(int productId)
    {
        cartCount++;
    }

    private string GetProductIcon(string? category) => category switch
    {
        "کتاب‌ها"          => "menu_book",
        "دوره‌های ویدیویی" => "smart_display",
        "بازی‌های فکری"   => "extension",
        "کیت‌های آموزشی"  => "science",
        _                   => "inventory_2"
    };
}
