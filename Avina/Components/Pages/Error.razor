@page "/Error"
@using System.Diagnostics

<PageTitle>خطا</PageTitle>

<h1 class="text-danger">خطا</h1>
<h2 class="text-danger">هنگام پردازش درخواست شما خطایی رخ داده است.</h2>

@if (ShowRequestId)
{
    <p>
        <strong>شناسه درخواست:</strong> <code>@RequestId</code>
    </p>
}

<h3>راهنمای توسعه</h3>
<p>
    با فعال‌کردن حالت توسعه، جزئیات بیشتری از خطا نمایش داده می‌شود.
</p>
<p>
    <strong>در نسخه عملیاتی، محیط توسعه نباید فعال باشد.</strong>
    این کار ممکن است اطلاعات حساس خطاها را به کاربران نهایی نمایش دهد.
    برای بررسی محلی خطاها، برنامه را در حالت توسعه اجرا کنید و سپس دوباره راه‌اندازی کنید.
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
