@page "/course/{Id:int}"
@rendermode InteractiveServer
@using Avina.Services
@using Avina.Data
@using Microsoft.EntityFrameworkCore
@inject AvinaDbContext Db
@inject AuthStateService AuthState
@inject NavigationManager Nav

<style>
.course-hero {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    border-radius: 1.25rem;
    overflow: hidden;
    margin-bottom: 2rem;
}
.course-hero-inner {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 0;
    align-items: stretch;
}
@@media (max-width: 768px) {
    .course-hero-inner { grid-template-columns: 1fr; }
    .course-enroll-card { border-radius: 0 0 1.25rem 1.25rem !important; }
}
.course-info-side {
    padding: 2.5rem;
}
.course-enroll-card {
    background: #1c2026;
    border-right: 1px solid #2a3040;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
}
.course-badge {
    display: inline-block;
    background: rgba(124,58,237,0.2);
    border: 1px solid rgba(124,58,237,0.5);
    color: #a78bfa;
    padding: 0.25rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
}
.course-title-main {
    font-size: 1.75rem;
    font-weight: 900;
    color: #f1f5f9;
    line-height: 1.3;
    margin-bottom: 1rem;
}
.course-desc {
    color: #94a3b8;
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
}
.course-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
}
.course-meta-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: #94a3b8;
}
.course-meta-item strong { color: #e2e8f0; }
.enroll-price {
    font-size: 2rem;
    font-weight: 900;
    color: #a78bfa;
    margin-bottom: 0.25rem;
}
.enroll-price.free { color: #7dd3a8; }
.btn-enroll {
    width: 100%;
    padding: 0.875rem;
    border-radius: 0.875rem;
    border: none;
    font-size: 1rem;
    font-weight: 700;
    font-family: 'Vazirmatn', sans-serif;
    cursor: pointer;
    transition: all 0.3s ease;
}
.btn-enroll-primary {
    background: linear-gradient(135deg, #7c3aed, #ec4899);
    color: white;
}
.btn-enroll-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(124,58,237,0.3); }
.btn-enroll-enrolled {
    background: rgba(125,211,168,0.15);
    border: 1px solid #7dd3a8;
    color: #7dd3a8;
    cursor: default;
}
.btn-exam {
    background: linear-gradient(135deg, #0ea5e9, #7c3aed);
    color: white;
}
.btn-exam:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(14,165,233,0.3); }
.lesson-list { list-style: none; padding: 0; margin: 0; }
.lesson-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    border-radius: 0.75rem;
    transition: background 0.2s;
    cursor: pointer;
}
.lesson-item:hover { background: rgba(255,255,255,0.04); }
.lesson-item.locked { cursor: default; }
.lesson-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(124,58,237,0.2);
    color: #a78bfa;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
}
.lesson-title { font-size: 0.875rem; font-weight: 600; color: #e2e8f0; flex: 1; }
.lesson-duration { font-size: 0.75rem; color: #64748b; }
.lesson-badge {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 9999px;
}
.lesson-badge.free { background: rgba(125,211,168,0.15); color: #7dd3a8; border: 1px solid rgba(125,211,168,0.3); }
.lesson-badge.locked { background: rgba(100,116,139,0.15); color: #64748b; border: 1px solid rgba(100,116,139,0.3); }
.learn-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    margin-bottom: 0.75rem;
    font-size: 0.875rem;
    color: #cbd5e1;
}
.learn-item::before { content: "✓"; color: #7dd3a8; font-weight: 900; flex-shrink: 0; margin-top: 1px; }
.video-preview-container {
    position: relative;
    width: 100%;
    background: #000;
    border-radius: 0.75rem;
    overflow: hidden;
    aspect-ratio: 16/9;
    margin-bottom: 1rem;
}
.video-preview-container video {
    width: 100%;
    height: 100%;
    object-fit: contain;
}
</style>

@if (loading)
{
    <div style="padding:4rem; text-align:center; color:#64748b;">در حال بارگذاری دوره...</div>
}
else if (course == null)
{
    <div style="padding:4rem; text-align:center; color:#f87171;">دوره یافت نشد.</div>
}
else
{
    <div style="padding:1.5rem 2rem; max-width:1100px; margin:0 auto;">

        <!-- Hero -->
        <div class="course-hero">
            <div class="course-hero-inner">
                <!-- Left: Info -->
                <div class="course-info-side">
                    <div class="course-badge">@course.Category • @course.Level</div>
                    <h1 class="course-title-main">@course.Title</h1>
                    <p class="course-desc">@course.Description</p>
                    <div class="course-meta-row">
                        <div class="course-meta-item">⭐ <strong>@course.Rating.ToString("F1")</strong> (@course.RatingCount نظر)</div>
                        <div class="course-meta-item">👥 <strong>@course.StudentCount</strong> دانش‌آموز</div>
                        <div class="course-meta-item">⏱️ <strong>@(course.DurationMinutes / 60)ساعت @(course.DurationMinutes % 60)دقیقه</strong></div>
                        <div class="course-meta-item">🌐 <strong>@course.Language</strong></div>
                    </div>
                    <div class="course-meta-item" style="margin-bottom:0.5rem;">👨‍🏫 مدرس: <strong style="margin-right:0.25rem;">@course.Instructor</strong></div>
                </div>

                <!-- Right: Enroll card -->
                <div class="course-enroll-card">
                    @if (!string.IsNullOrEmpty(course.PreviewVideoPath))
                    {
                        <div class="video-preview-container">
                            <video controls preload="metadata">
                                <source src="@course.PreviewVideoPath" />
                            </video>
                        </div>
                    }
                    else
                    {
                        <div style="width:100%; aspect-ratio:16/9; background:linear-gradient(135deg,#1e293b,#0f172a); border-radius:0.75rem; display:flex; align-items:center; justify-content:center; font-size:3.5rem; margin-bottom:0.5rem;">🎓</div>
                    }

                    @if (course.IsFree)
                    {
                        <div class="enroll-price free">رایگان</div>
                    }
                    else
                    {
                        <div class="enroll-price">@course.CoinPrice <span style="font-size:1.25rem;">🪙</span></div>
                        @if (!isEnrolled)
                        {
                            <div style="font-size:0.8rem; color:#64748b; margin-top:-0.5rem;">موجودی شما: @userCoins 🪙</div>
                        }
                    }

                    @if (isEnrolled || course.IsFree)
                    {
                        <button class="btn-enroll btn-enroll-enrolled">✓ ثبت‌نام شده‌اید</button>
                        @if (hasExam)
                        {
                            <button class="btn-enroll btn-exam" @onclick="GoToExam">📝 شرکت در آزمون</button>
                        }
                        @if (!string.IsNullOrEmpty(certNumber))
                        {
                            <div style="background:rgba(125,211,168,0.1); border:1px solid rgba(125,211,168,0.3); border-radius:0.75rem; padding:0.875rem; text-align:center;">
                                <div style="color:#7dd3a8; font-weight:700; font-size:0.875rem; margin-bottom:0.25rem;">🏆 گواهینامه دریافت شده</div>
                                <div style="color:#64748b; font-size:0.75rem;">@certNumber</div>
                            </div>
                        }
                    }
                    else if (AuthState.CurrentUser == null)
                    {
                        <a href="/login" class="btn-enroll btn-enroll-primary" style="display:block; text-align:center; text-decoration:none;">ورود برای ثبت‌نام</a>
                    }
                    else
                    {
                        <button class="btn-enroll btn-enroll-primary" @onclick="Enroll" disabled="@enrolling">
                            @(enrolling ? "در حال ثبت‌نام..." : $"ثبت‌نام ({course.CoinPrice} 🪙)")
                        </button>
                        @if (!string.IsNullOrEmpty(enrollError))
                        {
                            <div style="color:#f87171; font-size:0.8rem; text-align:center;">@enrollError</div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Two columns: lessons + what you learn -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:2rem;">

            <!-- Lessons -->
            <div>
                <h2 style="font-size:1.25rem; font-weight:800; color:#f1f5f9; margin-bottom:1.25rem;">📋 سرفصل‌ها (@lessons.Count درس)</h2>
                <ul class="lesson-list">
                    @foreach (var lesson in lessons)
                    {
                        bool canWatch = lesson.IsFreePreview || isEnrolled || course.IsFree;
                        <li class="lesson-item @(canWatch ? "" : "locked")" @onclick="@(() => { if(canWatch && !string.IsNullOrEmpty(lesson.VideoPath)) selectedLesson = lesson; })">
                            <div class="lesson-num">@lesson.Order</div>
                            <span class="lesson-title">@lesson.Title</span>
                            @if (lesson.DurationSeconds > 0)
                            {
                                <span class="lesson-duration">@(lesson.DurationSeconds / 60)دقیقه</span>
                            }
                            @if (lesson.IsFreePreview)
                            {
                                <span class="lesson-badge free">رایگان</span>
                            }
                            else if (!isEnrolled && !course.IsFree)
                            {
                                <span class="lesson-badge locked">🔒</span>
                            }
                        </li>
                    }
                </ul>

                @if (selectedLesson != null)
                {
                    <div style="margin-top:1.25rem; background:#1c2026; border-radius:1rem; overflow:hidden;">
                        <video controls style="width:100%;" preload="metadata">
                            <source src="@selectedLesson.VideoPath" />
                        </video>
                        <div style="padding:0.875rem;">
                            <p style="font-weight:700; color:#e2e8f0; font-size:0.9rem;">@selectedLesson.Title</p>
                            @if (!string.IsNullOrEmpty(selectedLesson.Description))
                            {
                                <p style="color:#94a3b8; font-size:0.8rem; margin-top:0.375rem;">@selectedLesson.Description</p>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- What you learn + Requirements -->
            <div>
                @if (whatYouLearn.Any())
                {
                    <h2 style="font-size:1.25rem; font-weight:800; color:#f1f5f9; margin-bottom:1.25rem;">💡 چه یاد می‌گیرید</h2>
                    <div style="background:#1c2026; border-radius:1rem; padding:1.5rem; margin-bottom:1.5rem;">
                        @foreach (var item in whatYouLearn)
                        {
                            <div class="learn-item">@item</div>
                        }
                    </div>
                }

                @if (requirements.Any())
                {
                    <h2 style="font-size:1.25rem; font-weight:800; color:#f1f5f9; margin-bottom:1.25rem;">📌 پیش‌نیازها</h2>
                    <div style="background:#1c2026; border-radius:1rem; padding:1.5rem;">
                        @foreach (var req in requirements)
                        {
                            <div style="display:flex; align-items:flex-start; gap:0.625rem; margin-bottom:0.75rem; font-size:0.875rem; color:#cbd5e1;">
                                <span style="color:#fbbf24; flex-shrink:0;">•</span> @req
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Avina.Models.Course? course;
    private List<Avina.Models.CourseLesson> lessons = new();
    private List<string> whatYouLearn = new();
    private List<string> requirements = new();
    private bool loading = true;
    private bool isEnrolled = false;
    private bool enrolling = false;
    private string? enrollError;
    private int userCoins = 0;
    private bool hasExam = false;
    private string? certNumber;
    private Avina.Models.CourseLesson? selectedLesson;

    protected override async Task OnInitializedAsync()
    {
        await LoadCourse();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadCourse();
    }

    private async Task LoadCourse()
    {
        loading = true;
        try
        {
            course = await Db.Courses
                .Include(c => c.Lessons.OrderBy(l => l.Order))
                .Include(c => c.Exams)
                .FirstOrDefaultAsync(c => c.Id == Id);

            if (course != null)
            {
                lessons = course.Lessons.ToList();
                whatYouLearn = course.WhatYouLearn?.Split('|', StringSplitOptions.RemoveEmptyEntries).ToList() ?? new();
                requirements = course.Requirements?.Split('|', StringSplitOptions.RemoveEmptyEntries).ToList() ?? new();
                hasExam = course.Exams.Any();

                var user = AuthState.CurrentUser;
                if (user != null)
                {
                    userCoins = user.Coin;
                    var enrollment = await Db.CourseEnrollments
                        .FirstOrDefaultAsync(e => e.UserId == user.Id && e.CourseId == Id);
                    isEnrolled = enrollment != null;

                    var cert = await Db.Certificates
                        .FirstOrDefaultAsync(c => c.UserId == user.Id && c.CourseId == Id);
                    certNumber = cert?.CertificateNumber;
                }
            }
        }
        finally { loading = false; }
    }

    private async Task Enroll()
    {
        var user = AuthState.CurrentUser;
        if (user == null || course == null) return;

        enrolling = true;
        enrollError = null;

        try
        {
            if (user.Coin < course.CoinPrice)
            {
                enrollError = $"کوین کافی نیست. نیاز: {course.CoinPrice}, موجودی: {user.Coin}";
                return;
            }

            var dbUser = await Db.Users.FindAsync(user.Id);
            if (dbUser == null) return;

            dbUser.Coin -= course.CoinPrice;
            course.StudentCount++;

            Db.CourseEnrollments.Add(new Avina.Models.UserCourseEnrollment
            {
                UserId = user.Id,
                CourseId = Id,
                CoinSpent = course.CoinPrice
            });

            await Db.SaveChangesAsync();
            isEnrolled = true;
            userCoins = dbUser.Coin;
            if (AuthState.CurrentUser != null) AuthState.CurrentUser.Coin = dbUser.Coin;
        }
        catch (Exception ex)
        {
            enrollError = "خطا در ثبت‌نام. دوباره تلاش کنید.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            enrolling = false;
        }
    }

    private void GoToExam() => Nav.NavigateTo($"/course/{Id}/exam");
}
