@page "/profile"
@using Avina.Models
@using Avina.Services
@inject IUserService UserService
@rendermode InteractiveServer

<div class="px-4 md:px-10 py-8 space-y-8 max-w-5xl">

    <!-- Profile Header Card -->
    <section class="animate-page">
        <div class="bg-surface-container-lowest rounded-2xl p-7 shadow-sm">
            <div class="flex flex-col md:flex-row items-center md:items-start gap-6">
                <!-- Avatar -->
                <div class="relative flex-shrink-0">
                    <div class="w-24 h-24 rounded-2xl overflow-hidden ring-4 ring-primary/30 shadow-xl">
                        <img src="https://i.pravatar.cc/150?img=1" alt="@currentUser?.Name" class="w-full h-full object-cover" />
                    </div>
                    <div class="absolute -bottom-2 -right-2 bg-tertiary-container text-on-tertiary-container text-[10px] font-black px-2 py-0.5 rounded-full shadow">سطح ۱۲</div>
                </div>

                <!-- Info -->
                <div class="flex-1 text-right">
                    <h2 class="text-2xl font-black text-on-background mb-0.5">@(currentUser?.Name ?? "بارگذاری...")</h2>
                    <p class="text-on-surface-variant text-sm mb-4">@(currentUser?.Role ?? "") · عضو از @(currentUser?.CreatedAt.ToString("MMMM yyyy") ?? "")</p>
                    <p class="text-on-surface text-sm leading-relaxed mb-5 max-w-md">@(currentUser?.Bio ?? "")</p>
                    <!-- Stats Row -->
                    <div class="flex gap-6 flex-wrap">
                        <div class="text-center">
                            <p class="text-xl font-black text-on-surface">@(currentUser?.Followers ?? 0)</p>
                            <p class="text-xs text-on-surface-variant">دنبال‌کننده</p>
                        </div>
                        <div class="w-px h-10 bg-outline-variant self-center"></div>
                        <div class="text-center">
                            <p class="text-xl font-black text-on-surface">@(currentUser?.Following ?? 0)</p>
                            <p class="text-xs text-on-surface-variant">دنبال‌شونده</p>
                        </div>
                        <div class="w-px h-10 bg-outline-variant self-center"></div>
                        <div class="text-center">
                            <p class="text-xl font-black text-yellow-400">@(currentUser?.Coin ?? 0)</p>
                            <p class="text-xs text-on-surface-variant">سکه</p>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="flex flex-col gap-2 flex-shrink-0">
                    <button class="primary-gradient text-white px-6 py-2.5 rounded-xl font-bold text-sm hover:opacity-90 active:scale-95 transition-all"
                            @onclick="EditProfile">
                        ویرایش پروفایل
                    </button>
                    <button class="bg-surface-container-low text-on-surface px-6 py-2.5 rounded-xl font-bold text-sm hover:bg-surface-container-high active:scale-95 transition-all"
                            @onclick="Logout">
                        خروج از حساب
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick Stats -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-4 animate-page delay-1">
        @foreach (var stat in quickStats)
        {
            <div class="bg-surface-container-low rounded-2xl p-5 text-right card-lift">
                <div class="w-10 h-10 rounded-xl mb-3 flex items-center justify-center" style="background: @stat.BgColor;">
                    <span class="material-symbols-outlined text-xl" style="color: @stat.IconColor; font-variation-settings:'FILL' 1;">@stat.Icon</span>
                </div>
                <p class="text-2xl font-black text-on-surface">@stat.Value</p>
                <p class="text-xs text-on-surface-variant">@stat.Label</p>
            </div>
        }
    </section>

    <!-- Tabs -->
    <section class="animate-page delay-2">
        <div class="flex gap-2 border-b border-outline-variant/30 mb-6 overflow-x-auto hide-scrollbar">
            @foreach (var tab in tabs)
            {
                <button class="@GetTabClass(tab) whitespace-nowrap px-5 py-2.5 font-bold text-sm transition-all rounded-t-xl"
                        @onclick="() => SetTab(tab)">@tab</button>
            }
        </div>

        <!-- Achievements Tab -->
        @if (activeTab == "دستاوردها")
        {
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
                @foreach (var achievement in achievements)
                {
                    <div class="bg-surface-container-lowest rounded-2xl p-5 flex flex-col items-center gap-3 card-lift shadow-sm">
                        <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center">
                            <span class="material-symbols-outlined text-3xl text-primary" style="font-variation-settings:'FILL' 1;">@achievement.Icon</span>
                        </div>
                        <div class="text-center">
                            <h4 class="font-bold text-sm text-on-surface">@achievement.Title</h4>
                            <p class="text-xs text-on-surface-variant">@achievement.Desc</p>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- My Courses Tab -->
        @if (activeTab == "دوره‌های من")
        {
            <div class="space-y-4">
                @foreach (var (course, pct) in enrolledCourses)
                {
                    <div class="bg-surface-container-lowest rounded-2xl p-5 flex items-center gap-5 card-lift shadow-sm">
                        <div class="w-16 h-16 rounded-xl bg-surface-container-high flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-2xl text-on-surface-variant">play_lesson</span>
                        </div>
                        <div class="flex-1 text-right">
                            <h4 class="font-bold text-on-surface mb-0.5">@course.Title</h4>
                            <p class="text-xs text-on-surface-variant mb-2">@course.Instructor</p>
                            <div class="h-2 w-full bg-surface-container-highest rounded-full overflow-hidden">
                                <div class="h-full primary-gradient rounded-full progress-bar" style="width:@pct%;"></div>
                            </div>
                            <p class="text-xs text-on-surface-variant mt-1">@pct٪ تکمیل شده</p>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Activities Tab -->
        @if (activeTab == "فعالیت‌ها")
        {
            <div class="space-y-3">
                @foreach (var (activity, index) in recentActivities.Select((a, i) => (a, i)))
                {
                    <div class="flex items-center gap-4 bg-surface-container-lowest rounded-2xl p-4 shadow-sm">
                        <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings:'FILL' 1;">@activity.Icon</span>
                        </div>
                        <div class="flex-1 text-right">
                            <h4 class="font-bold text-sm text-on-surface">@activity.Title</h4>
                            <p class="text-xs text-on-surface-variant">@activity.Time</p>
                        </div>
                        <div class="flex items-center gap-1 text-tertiary flex-shrink-0">
                            <span class="font-black text-sm">+@activity.Points</span>
                            <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">monetization_on</span>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Settings Tab -->
        @if (activeTab == "تنظیمات")
        {
            <div class="bg-surface-container-lowest rounded-2xl p-7 shadow-sm space-y-5">
                <div>
                    <label class="block text-sm font-bold text-on-surface mb-2">ایمیل</label>
                    <input type="email"
                           class="w-full bg-surface-container-low rounded-xl px-4 py-3 text-on-surface border border-outline-variant/30 focus:outline-none focus:border-primary text-right"
                           value="@(currentUser?.Email ?? "")" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-on-surface mb-2">بیوگرافی</label>
                    <textarea class="w-full bg-surface-container-low rounded-xl px-4 py-3 text-on-surface border border-outline-variant/30 focus:outline-none focus:border-primary text-right resize-none"
                              rows="3">@(currentUser?.Bio ?? "")</textarea>
                </div>
                <div class="flex items-center justify-between p-4 bg-surface-container-low rounded-xl">
                    <span class="text-sm font-bold">اطلاع‌رسانی‌های پوش</span>
                    <div class="w-12 h-6 bg-primary rounded-full relative cursor-pointer">
                        <div class="w-5 h-5 bg-white rounded-full absolute left-0.5 top-0.5 shadow transition-all"></div>
                    </div>
                </div>
                <button class="primary-gradient text-white px-6 py-2.5 rounded-xl font-bold text-sm hover:opacity-90 active:scale-95 transition-all"
                        @onclick="SaveSettings">
                    ذخیره تغییرات
                </button>
            </div>
        }
    </section>
</div>

@code {
    private User? currentUser;
    private string activeTab = "دستاوردها";
    private string[] tabs = { "دستاوردها", "دوره‌های من", "فعالیت‌ها", "تنظیمات" };

    private record StatItem(string Icon, string Value, string Label, string BgColor, string IconColor);
    private record AchievementItem(string Icon, string Title, string Desc);
    private record ActivityItem(string Icon, string Title, string Time, int Points);

    private List<StatItem> quickStats = new();
    private List<AchievementItem> achievements = new();
    private List<(Course course, int pct)> enrolledCourses = new();
    private List<ActivityItem> recentActivities = new();

    protected override async Task OnInitializedAsync()
    {
        currentUser = await UserService.GetCurrentUserAsync();

        quickStats = new()
        {
            new("school",       "۱۲", "دوره تکمیل‌شده",  "rgba(170,199,255,0.1)", "#aac7ff"),
            new("military_tech","۸",  "مدال کسب‌شده",   "rgba(255,182,140,0.1)", "#ffb68c"),
            new("local_fire_department","۲۴","روز پیاپی", "rgba(231,65,31,0.1)",  "#e3711f"),
            new("monetization_on","۲,۴۵۰","امتیاز کل",   "rgba(255,200,0,0.1)",  "#fbbf24"),
        };

        achievements = new()
        {
            new("emoji_events",    "قهرمان اول",     "اولین مکان در رقابت"),
            new("science",         "دانشمند کوچک",   "۵ آزمایش علمی"),
            new("local_fire_department","۷ روز پیاپی","یک هفته بدون وقفه"),
            new("translate",       "سفیر زبان",      "۱۰۰ لغت یاد گرفته"),
            new("calculate",       "استاد ریاضی",    "۵۰ مسئله حل شده"),
            new("history_edu",     "کاوشگر تاریخ",   "۱۰ درس تاریخ"),
        };

        enrolledCourses = new()
        {
            (new Course { Title = "ریاضی پایه",       Instructor = "محمد علی"    }, 68),
            (new Course { Title = "علوم طبیعی",       Instructor = "فاطمه احمدی" }, 32),
            (new Course { Title = "مهارت‌های زندگی",  Instructor = "علی رضائی"  }, 15),
        };

        recentActivities = new()
        {
            new("school",          "دوره 'ریاضی پایه' شروع شد",       "۲ ساعت پیش",  50),
            new("military_tech",   "مدال 'درخشندگی' کسب شد",          "دیروز",       100),
            new("quiz",            "آزمون 'فصل اول' با ۹۵٪ قبول",     "۲ روز پیش",  80),
            new("group",           "در ماموریت اجتماعی شرکت شد",      "۳ روز پیش",  30),
        };
    }

    private string GetTabClass(string tab) =>
        activeTab == tab
            ? "border-b-2 border-primary text-primary bg-primary/5"
            : "text-on-surface-variant hover:text-on-surface hover:bg-surface-container-low";

    private void SetTab(string tab) => activeTab = tab;
    private void EditProfile()     => Console.WriteLine("ویرایش پروفایل");
    private void Logout()          => Console.WriteLine("خروج");
    private void SaveSettings()    => Console.WriteLine("ذخیره تنظیمات");
}
