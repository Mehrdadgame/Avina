@page "/profile"
@using Avina.Models
@rendermode InteractiveServer

<div class="container mt-5">
    <!-- Profile Header -->
    <section class="profile-header mb-5">
        <div class="row">
            <div class="col-lg-8">
                <div class="profile-card bg-white p-5 rounded-4 shadow-sm">
                    <div class="row align-items-center">
                        <div class="col-md-3 text-center">
                            <img src="@currentUser?.ProfileImage" alt="@currentUser?.Name" class="rounded-circle" style="width: 150px; height: 150px; object-fit: cover;">
                            <h3 class="mt-3 mb-0">@currentUser?.Name</h3>
                            <p class="text-muted">@currentUser?.Role</p>
                        </div>
                        <div class="col-md-9">
                            <p class="mb-3">@currentUser?.Bio</p>
                            <div class="row g-3 mb-4">
                                <div class="col-md-4">
                                    <div class="stat p-3 rounded-3 bg-light">
                                        <h5 class="text-primary mb-1">@currentUser?.Followers</h5>
                                        <p class="text-muted mb-0">دنبال‌کننده</p>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="stat p-3 rounded-3 bg-light">
                                        <h5 class="text-success mb-1">@currentUser?.Following</h5>
                                        <p class="text-muted mb-0">دنبال‌شونده</p>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="stat p-3 rounded-3 bg-light">
                                        <h5 class="text-warning mb-1">@currentUser?.Coin</h5>
                                        <p class="text-muted mb-0">کوین</p>
                                    </div>
                                </div>
                            </div>
                            <button class="btn btn-primary me-2" @onclick="EditProfile">ویرایش پروفایل</button>
                            <button class="btn btn-outline-secondary" @onclick="Logout">خروج</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="quick-stats bg-white p-4 rounded-4 shadow-sm">
                    <h5 class="fw-bold mb-4">آمار سریع</h5>
                    <div class="stat-item d-flex justify-content-between mb-3">
                        <span>دوره‌های مکمل‌شده</span>
                        <strong>12</strong>
                    </div>
                    <div class="stat-item d-flex justify-content-between mb-3">
                        <span>مدال کسب‌شده</span>
                        <strong>8</strong>
                    </div>
                    <div class="stat-item d-flex justify-content-between mb-3">
                        <span>روز بدون قطع</span>
                        <strong>24</strong>
                    </div>
                    <div class="stat-item d-flex justify-content-between">
                        <span>امتیاز کل</span>
                        <strong>2,450</strong>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Tabs Navigation -->
    <section class="mb-5">
        <ul class="nav nav-tabs" id="profileTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="achievements-tab" data-bs-toggle="tab" data-bs-target="#achievements" type="button" role="tab">دستاوردها</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="courses-tab" data-bs-toggle="tab" data-bs-target="#courses" type="button" role="tab">دوره‌های من</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="activities-tab" data-bs-toggle="tab" data-bs-target="#activities" type="button" role="tab">فعالیت‌های اخیر</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="settings-tab" data-bs-toggle="tab" data-bs-target="#settings" type="button" role="tab">تنظیمات</button>
            </li>
        </ul>

        <div class="tab-content" id="profileTabsContent">
            <!-- Achievements Tab -->
            <div class="tab-pane fade show active" id="achievements" role="tabpanel" aria-labelledby="achievements-tab">
                <div class="mt-4">
                    <h5 class="fw-bold mb-4">مدال‌های کسب‌شده</h5>
                    <div class="row g-4">
                        @foreach (var achievement in achievements)
                        {
                            <div class="col-md-3">
                                <div class="achievement-card text-center p-4 rounded-4 border">
                                    <div class="achievement-icon mb-3" style="font-size: 3rem;">@achievement</div>
                                    <p class="text-muted">@achievement</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Courses Tab -->
            <div class="tab-pane fade" id="courses" role="tabpanel" aria-labelledby="courses-tab">
                <div class="mt-4">
                    <h5 class="fw-bold mb-4">دوره‌های ثبت‌نام‌شده</h5>
                    <div class="row g-4">
                        @foreach (var course in enrolledCourses)
                        {
                            <div class="col-lg-6">
                                <div class="course-item d-flex gap-3 p-4 rounded-4 border">
                                    <img src="@course.ThumbnailImage" alt="@course.Title" style="width: 120px; height: 120px; object-fit: cover; border-radius: 8px;">
                                    <div class="flex-grow-1">
                                        <h6 class="fw-bold mb-1">@course.Title</h6>
                                        <p class="text-muted mb-2">@course.Instructor</p>
                                        <div class="progress" style="height: 5px;">
                                            <div class="progress-bar" role="progressbar" style="width: 65%;" aria-valuenow="65" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                        <small class="text-muted">65% مکمل</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Activities Tab -->
            <div class="tab-pane fade" id="activities" role="tabpanel" aria-labelledby="activities-tab">
                <div class="mt-4">
                    <h5 class="fw-bold mb-4">فعالیت‌های اخیر</h5>
                    <div class="timeline">
                        @foreach (var activity in recentActivities)
                        {
                            <div class="timeline-item d-flex gap-3 mb-4">
                                <div class="timeline-marker">
                                    <div class="marker-circle"></div>
                                </div>
                                <div class="timeline-content p-3 rounded-4 bg-light flex-grow-1">
                                    <h6 class="fw-bold">@activity</h6>
                                    <small class="text-muted">@DateTime.Now.ToString("g")</small>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Settings Tab -->
            <div class="tab-pane fade" id="settings" role="tabpanel" aria-labelledby="settings-tab">
                <div class="mt-4">
                    <h5 class="fw-bold mb-4">تنظیمات</h5>
                    <form>
                        <div class="mb-3">
                            <label for="email" class="form-label">ایمیل</label>
                            <input type="email" class="form-control" id="email" value="@currentUser?.Email" />
                        </div>
                        <div class="mb-3">
                            <label for="bio" class="form-label">بیوگرافی</label>
                            <textarea class="form-control" id="bio" rows="3">@currentUser?.Bio</textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-check-label">
                                <input type="checkbox" class="form-check-input" checked />
                                اطلاع‌رسانی‌های پوش‌نوتیفیکیشن
                            </label>
                        </div>
                        <button type="button" class="btn btn-primary" @onclick="SaveSettings">ذخیره تغییرات</button>
                    </form>
                </div>
            </div>
        </div>
    </section>
</div>

