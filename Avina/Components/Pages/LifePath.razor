@page "/life-path"
@rendermode InteractiveServer

<div class="p-5 md:p-8 lg:p-10 space-y-8 overflow-x-hidden">

    <!-- Page Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 animate-page">
        <div>
            <h1 class="text-3xl md:text-4xl font-black text-on-background mb-1">آخرین نگهبان</h1>
            <p class="text-on-surface-variant">تحلیل مسیر رشد و شکوفایی استعدادهای تو</p>
        </div>
        <div class="flex items-center gap-2 bg-surface-container-low p-1.5 rounded-full">
            <button class="@GetPeriodClass("monthly") px-5 py-1.5 rounded-full text-sm font-medium transition-colors" @onclick='() => SetPeriod("monthly")'>ماهانه</button>
            <button class="@GetPeriodClass("weekly") px-5 py-1.5 rounded-full text-sm font-bold transition-colors" @onclick='() => SetPeriod("weekly")'>هفتگی</button>
        </div>
    </div>

    <!-- Top Bento Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

        <!-- Talent Profile -->
        <div class="lg:col-span-7 bg-surface-container-low rounded-2xl p-7 relative overflow-hidden card-lift animate-page delay-1">
            <div class="relative z-10">
                <div class="flex justify-between items-start mb-6">
                    <div>
                        <h2 class="text-xl font-extrabold text-on-background mb-1">پروفایل استعداد</h2>
                        <p class="text-on-surface-variant text-sm">نقاط قوت غالب شما بر اساس فعالیت‌های اخیر</p>
                    </div>
                    <span class="material-symbols-outlined text-primary text-4xl">psychology</span>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
                    <div class="space-y-5">
                        @foreach (var talent in talents)
                        {
                            <div>
                                <div class="flex justify-between mb-1.5">
                                    <span class="font-bold text-sm">@talent.Name</span>
                                    <span class="font-bold text-sm" style="color: @talent.Color;">@talent.Percent٪</span>
                                </div>
                                <div class="w-full h-2.5 bg-surface-container-highest rounded-full overflow-hidden">
                                    <div class="h-full rounded-full progress-bar"
                                         style="width:@(talent.Percent)%; background: linear-gradient(to left, @talent.Color, @talent.ColorLight); animation-delay:@(talent.Delay)s;"></div>
                                </div>
                            </div>
                        }
                    </div>
                    <!-- Growth Index Circle -->
                    <div class="flex justify-center relative">
                        <div class="w-40 h-40 rounded-full border-8 border-white flex items-center justify-center relative bg-white shadow-xl">
                            <span class="material-symbols-outlined text-5xl text-primary opacity-10 absolute">star</span>
                            <div class="text-center relative z-10">
                                <span class="block text-4xl font-black text-primary">۷۴</span>
                                <span class="text-xs text-on-surface-variant font-bold">شاخص رشد</span>
                            </div>
                        </div>
                        <div class="badge-float absolute -top-3 -right-3 bg-tertiary-container text-on-tertiary-container px-3 py-1.5 rounded-xl font-bold shadow-lg border-white border-4 text-xs">تفکر تحلیلی</div>
                    </div>
                </div>
            </div>
            <div class="absolute top-0 right-0 w-48 h-48 bg-primary opacity-5 rounded-full -mr-24 -mt-24 pointer-events-none"></div>
        </div>

        <!-- Test CTA -->
        <div class="lg:col-span-5 animate-page delay-2">
            <div class="h-full bg-gradient-to-br from-secondary-container to-secondary rounded-2xl p-7 text-white relative overflow-hidden shadow-xl cursor-pointer active:scale-95 transition-transform min-h-[200px]">
                <div class="relative z-10 flex flex-col h-full">
                    <h2 class="text-2xl font-black mb-3 leading-tight">تست جدید<br />استعدادیابی</h2>
                    <p class="text-white/80 text-sm mb-6 leading-relaxed">خودت رو بهتر بشناس و مسیر قهرمانیت رو همین امروز بساز.</p>
                    <div class="mt-auto flex items-center gap-2 font-bold text-sm">
                        <span>شروع آزمون</span>
                        <span class="material-symbols-outlined">arrow_back</span>
                    </div>
                </div>
                <span class="material-symbols-outlined absolute -bottom-6 -left-6 text-[10rem] opacity-15 -rotate-12 pointer-events-none">lightbulb</span>
            </div>
        </div>
    </div>

    <!-- Weekly Planner + Mood Tracker -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 animate-page delay-3">

        <!-- Weekly Planner -->
        <div class="lg:col-span-2 bg-surface-container-low rounded-2xl p-7">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-extrabold text-on-background">برنامه‌ریز هفته</h2>
                <span class="text-on-surface-variant text-xs font-medium bg-surface-container-lowest px-3 py-1 rounded-full">تعادل: عالی</span>
            </div>
            <div class="flex items-end justify-between gap-1.5 h-52">
                @foreach (var day in weekDays)
                {
                    <div class="flex-1 flex flex-col items-center gap-2 h-full cursor-default">
                        <div class="flex-1 w-full flex flex-col justify-end gap-0.5">
                            <div class="w-full bg-secondary-container rounded-t opacity-80" style="height:@(day.Game)%"></div>
                            <div class="w-full bg-primary-container opacity-80" style="height:@(day.Study)%"></div>
                            <div class="w-full bg-surface-container-highest rounded-b opacity-80" style="height:@(day.Rest)%"></div>
                        </div>
                        <span class="text-[10px] font-bold text-on-surface-variant">@day.Name</span>
                    </div>
                }
            </div>
            <div class="mt-6 flex flex-wrap gap-5 justify-center">
                <div class="flex items-center gap-2">
                    <div class="w-3 h-3 rounded-full bg-primary-container"></div>
                    <span class="text-xs font-bold">آموزش</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-3 h-3 rounded-full bg-secondary-container"></div>
                    <span class="text-xs font-bold">بازی</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-3 h-3 rounded-full bg-surface-container-highest"></div>
                    <span class="text-xs font-bold">استراحت</span>
                </div>
            </div>
        </div>

        <!-- Mood Tracker -->
        <div class="bg-surface-container-lowest rounded-2xl p-7 shadow-sm flex flex-col">
            <h2 class="text-xl font-extrabold text-on-background mb-1">حالت روحی امروز</h2>
            <p class="text-on-surface-variant text-sm mb-6">یک آیکون را برای ثبت انتخاب کن</p>
            <div class="grid grid-cols-2 gap-3 flex-1">
                @foreach (var mood in moods)
                {
                    <button class="flex flex-col items-center justify-center p-5 rounded-xl transition-all duration-200 @(selectedMood == mood.Key ? mood.ActiveClass : "bg-surface-container-low hover:bg-surface-container-high")"
                            @onclick="() => SelectMood(mood.Key)">
                        <span class="material-symbols-outlined text-3xl mb-2 @(selectedMood == mood.Key ? "text-white" : "text-on-surface-variant")"
                              style="font-variation-settings:'FILL' 1;">@mood.Icon</span>
                        <span class="font-bold text-sm">@mood.Label</span>
                    </button>
                }
            </div>
            <div class="mt-5 bg-surface-container-low p-3.5 rounded-xl flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-tertiary text-lg">history</span>
                    <span class="text-xs font-bold">ثبت شده در ۷ روز گذشته</span>
                </div>
                <span class="text-xs font-black text-tertiary">۱۰۰٪</span>
            </div>
        </div>
    </div>

    <!-- Quote -->
    <div class="rounded-2xl overflow-hidden min-h-[220px] flex items-center justify-center p-8 text-center bg-surface-container-highest animate-page delay-3">
        <div class="max-w-xl mx-auto">
            <span class="material-symbols-outlined text-4xl text-primary mb-3 block">format_quote</span>
            <h3 class="text-xl md:text-2xl font-black text-on-background leading-relaxed italic mb-3">
                «هر قدمی که برای شناخت خودت برمی‌داری، مسیری جدید به سوی جهانی ناشناخته باز می‌کنی.»
            </h3>
            <p class="text-on-surface-variant font-bold">— راهنمای کهن</p>
        </div>
    </div>

</div>

@code {
    private string activePeriod = "weekly";
    private string selectedMood = "";

    private record TalentItem(string Name, int Percent, string Color, string ColorLight, string Delay);
    private record WeekDay(string Name, int Study, int Game, int Rest);
    private record MoodItem(string Key, string Icon, string Label, string ActiveClass);

    private List<TalentItem> talents = new()
    {
        new("منطقی و ریاضی", 85, "#aac7ff", "#4090fe", "0.2"),
        new("هنری و خلاق",   62, "#afc7f7", "#2e4770", "0.4"),
        new("اجتماعی و همدلی", 45, "#ffb68c", "#e3711f", "0.6"),
    };

    private List<WeekDay> weekDays = new()
    {
        new("یکشنبه",  40, 30, 20),
        new("دوشنبه",  50, 20, 25),
        new("سه‌شنبه", 30, 40, 15),
        new("چهارشنبه",45, 25, 25),
        new("پنج‌شنبه",60, 10, 20),
        new("جمعه",    10, 50, 40),
        new("شنبه",    50, 20, 10),
    };

    private List<MoodItem> moods = new()
    {
        new("great",  "sentiment_very_satisfied", "عالی",   "bg-tertiary-container"),
        new("good",   "sentiment_satisfied",      "خوب",    "bg-primary-container"),
        new("normal", "sentiment_neutral",        "معمولی", "bg-surface-container-high"),
        new("tired",  "sentiment_dissatisfied",   "خسته",   "bg-error-container"),
    };

    private string GetPeriodClass(string period)
        => activePeriod == period
            ? "bg-white text-primary shadow-sm"
            : "text-on-surface hover:bg-white/50 transition-colors";

    private void SetPeriod(string period) => activePeriod = period;
    private void SelectMood(string mood) => selectedMood = mood;
}
