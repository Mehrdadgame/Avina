@page "/"
@rendermode InteractiveServer

<div class="px-4 md:px-10 py-8 overflow-x-hidden">

    <!-- Greeting -->
    <section class="mb-8 animate-page">
        <h1 class="text-3xl md:text-4xl font-black text-on-background mb-1">سلام آریای قهرمان! 👋</h1>
        <p class="text-on-surface-variant">آماده‌ای برای ماجراجویی امروز در «آخرین نگهبان»؟</p>
    </section>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5">

        <!-- Mission Hero Card -->
        <div class="lg:col-span-8 bg-surface-container-lowest rounded-2xl p-7 relative overflow-hidden flex flex-col justify-between min-h-[300px] card-lift animate-page delay-1">
            <div class="relative z-10">
                <div class="inline-flex items-center gap-2 bg-tertiary-container text-on-tertiary-container px-3 py-1 rounded-full text-xs font-bold mb-4">
                    <span class="material-symbols-outlined text-sm">flag</span>
                    <span>ماموریت امروز</span>
                </div>
                <h2 class="text-2xl md:text-3xl font-black mb-3 max-w-md leading-tight text-on-surface">راز کتیبه‌های باستانی: بخش دوم</h2>
                <p class="text-on-surface-variant mb-6 max-w-sm text-sm leading-relaxed">با حل این معما، ۲۰ امتیاز تجربه و ۵ سکه طلا دریافت خواهی کرد.</p>
            </div>
            <div class="relative z-10">
                <div class="flex justify-between items-end mb-2">
                    <span class="text-xs font-bold text-on-surface-variant">پیشرفت ماموریت</span>
                    <span class="text-xs font-black text-primary">۶۵٪</span>
                </div>
                <div class="w-full h-2.5 bg-surface-container-highest rounded-full overflow-hidden mb-5">
                    <div class="h-full primary-gradient rounded-full progress-bar" style="width:65%; animation-delay:0.4s;"></div>
                </div>
                <button class="primary-gradient text-white px-7 py-2.5 rounded-xl font-bold flex items-center gap-2 w-fit hover:opacity-90 active:scale-95 transition-all duration-200">
                    <span>ادامه ماموریت</span>
                    <span class="material-symbols-outlined text-lg">play_arrow</span>
                </button>
            </div>
            <!-- Background Icon -->
            <div class="absolute -top-10 -left-10 w-56 h-56 opacity-[0.07] pointer-events-none">
                <span class="material-symbols-outlined text-[200px] text-on-surface" style="font-variation-settings:'FILL' 1;">castle</span>
            </div>
        </div>

        <!-- Side Cards -->
        <div class="lg:col-span-4 flex flex-col gap-4">

            <!-- Continue Learning -->
            <div class="bg-surface-container-low rounded-2xl p-5 flex-1 border-r-4 border-primary card-lift animate-page delay-2">
                <h3 class="text-base font-bold mb-3 flex items-center justify-between">
                    <span>ادامه یادگیری</span>
                    <span class="material-symbols-outlined text-primary text-xl">history</span>
                </h3>
                <a href="/school" class="block aspect-video rounded-xl overflow-hidden mb-3 relative group">
                    <img src="https://images.unsplash.com/photo-1518152006812-edab29b069ac?w=400&q=80" alt=""
                         class="w-full h-full object-cover transition-transform duration-400 group-hover:scale-105" />
                    <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                        <span class="material-symbols-outlined text-white text-5xl group-hover:scale-110 transition-transform duration-300"
                              style="font-variation-settings:'FILL' 1;">play_circle</span>
                    </div>
                </a>
                <h4 class="font-bold text-on-surface text-sm mb-0.5">درس ۴: ساختار اتم</h4>
                <p class="text-xs text-on-surface-variant">آخرین مشاهده: دیروز</p>
            </div>

            <!-- Level Badge -->
            <div class="bg-secondary-container text-on-secondary-container rounded-2xl p-5 flex items-center justify-between card-lift animate-page delay-3">
                <div>
                    <p class="text-xs font-medium mb-0.5">سطح شما</p>
                    <p class="text-xl font-black">نبردآموز ۱۲</p>
                </div>
                <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-2xl">military_tech</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Daily Challenges -->
    <section class="mt-10 animate-page delay-4">
        <div class="flex items-center justify-between mb-5">
            <h2 class="text-xl font-black text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-tertiary" style="font-variation-settings:'FILL' 1;">local_fire_department</span>
                چالش‌های روزانه
            </h2>
            <a href="#" class="text-primary font-bold text-sm hover:underline">مشاهده همه</a>
        </div>

        <div class="flex overflow-x-auto gap-4 pb-4 hide-scrollbar -mx-4 px-4 snap-scroll">

            <!-- Challenge 1 -->
            <div class="snap-item min-w-[270px] bg-surface-container-lowest rounded-2xl p-5 shadow-sm border-t-4 border-tertiary card-lift flex-shrink-0">
                <div class="flex justify-between items-start mb-4">
                    <div class="w-11 h-11 rounded-xl bg-tertiary/10 flex items-center justify-center text-tertiary">
                        <span class="material-symbols-outlined text-2xl" style="font-variation-settings:'FILL' 1;">calculate</span>
                    </div>
                    <span class="text-xs font-bold text-tertiary bg-tertiary-container/20 px-2 py-1 rounded-full">+۵۰ امتیاز</span>
                </div>
                <h3 class="font-bold text-on-surface mb-2">استاد محاسبات</h3>
                <p class="text-xs text-on-surface-variant mb-5 leading-relaxed">۱۰ مسئله ریاضی سطح متوسط را در کمتر از ۵ دقیقه حل کن.</p>
                <button class="w-full py-2 border border-outline-variant text-on-surface font-bold rounded-xl hover:bg-surface-container-low active:scale-95 transition-all duration-200 text-sm">شروع چالش</button>
            </div>

            <!-- Challenge 2 -->
            <div class="snap-item min-w-[270px] bg-surface-container-lowest rounded-2xl p-5 shadow-sm border-t-4 border-secondary card-lift flex-shrink-0">
                <div class="flex justify-between items-start mb-4">
                    <div class="w-11 h-11 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary">
                        <span class="material-symbols-outlined text-2xl" style="font-variation-settings:'FILL' 1;">translate</span>
                    </div>
                    <span class="text-xs font-bold text-secondary bg-secondary-container/20 px-2 py-1 rounded-full">+۳۰ امتیاز</span>
                </div>
                <h3 class="font-bold text-on-surface mb-2">سفیر زبان</h3>
                <p class="text-xs text-on-surface-variant mb-5 leading-relaxed">۲۰ لغت جدید انگلیسی را امروز یاد بگیر و در آزمون شرکت کن.</p>
                <button class="w-full py-2 border border-outline-variant text-on-surface font-bold rounded-xl hover:bg-surface-container-low active:scale-95 transition-all duration-200 text-sm">شروع چالش</button>
            </div>

            <!-- Challenge 3 -->
            <div class="snap-item min-w-[270px] bg-surface-container-lowest rounded-2xl p-5 shadow-sm border-t-4 border-primary card-lift flex-shrink-0">
                <div class="flex justify-between items-start mb-4">
                    <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined text-2xl" style="font-variation-settings:'FILL' 1;">science</span>
                    </div>
                    <span class="text-xs font-bold text-primary bg-primary-container/20 px-2 py-1 rounded-full">+۸۰ امتیاز</span>
                </div>
                <h3 class="font-bold text-on-surface mb-2">دانشمند کوچک</h3>
                <p class="text-xs text-on-surface-variant mb-5 leading-relaxed">ویدئوی آزمایش شیمی را ببین و به ۳ سوال نهایی پاسخ درست بده.</p>
                <button class="w-full py-2 border border-outline-variant text-on-surface font-bold rounded-xl hover:bg-surface-container-low active:scale-95 transition-all duration-200 text-sm">شروع چالش</button>
            </div>

            <!-- Challenge 4 -->
            <div class="snap-item min-w-[270px] bg-surface-container-lowest rounded-2xl p-5 shadow-sm border-t-4 border-outline card-lift flex-shrink-0">
                <div class="flex justify-between items-start mb-4">
                    <div class="w-11 h-11 rounded-xl bg-outline/10 flex items-center justify-center text-outline">
                        <span class="material-symbols-outlined text-2xl" style="font-variation-settings:'FILL' 1;">history_edu</span>
                    </div>
                    <span class="text-xs font-bold text-outline bg-surface-container-high/40 px-2 py-1 rounded-full">+۴۰ امتیاز</span>
                </div>
                <h3 class="font-bold text-on-surface mb-2">کاوشگر تاریخ</h3>
                <p class="text-xs text-on-surface-variant mb-5 leading-relaxed">درباره ۳ تمدن بزرگ باستانی تحقیق کن و گزارش کوتاهی بنویس.</p>
                <button class="w-full py-2 border border-outline-variant text-on-surface font-bold rounded-xl hover:bg-surface-container-low active:scale-95 transition-all duration-200 text-sm">شروع چالش</button>
            </div>
        </div>
    </section>
</div>
