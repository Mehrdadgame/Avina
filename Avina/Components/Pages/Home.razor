@code {
    private HomeSectionsDto? homeSections;
    private bool sectionsLoading = true;

    private static string ContentTypeIcon(string type) => type switch
    {
        "Video" => "🎬",
        "Audio" => "🎵",
        "PDF" => "📄",
        "Image" => "🖼️",
        _ => "📁"
    };

    private class HeroSlide
    {
        public string Image { get; set; } = "";
        public string Badge { get; set; } = "";
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string PrimaryLabel { get; set; } = "";
        public string PrimaryLink { get; set; } = "";
        public string SecondaryLabel { get; set; } = "";
        public string SecondaryLink { get; set; } = "";
        public string Stat1 { get; set; } = "";
        public string Stat1Label { get; set; } = "";
        public string Stat2 { get; set; } = "";
        public string Stat2Label { get; set; } = "";
    }

    private static readonly string[] CourseImages = {
        "https://images.unsplash.com/photo-1635070041078-e363dbe005cb?w=400&q=80",
        "https://images.unsplash.com/photo-1532094349884-543bc11b234d?w=400&q=80",
        "https://images.unsplash.com/photo-1516116216624-53e697900ea0?w=400&q=80",
        "https://images.unsplash.com/photo-1434030216411-0b793f4b6f97?w=400&q=80",
    };

    private List<HeroSlide> heroSlides = new();
    private int heroIndex = 0;
    private System.Threading.Timer? _carouselTimer;
    private string activeDiscoveryFilter = "all";
    private readonly (string Key, string Label)[] discoveryFilters =
    [
        ("all", "همه"),
        ("school", "مدرسه"),
        ("game", "بازی"),
        ("study", "مطالعه"),
        ("skill", "مهارت")
    ];

    private IEnumerable<HomeDiscoverItemDto> VisibleDiscoverItems =>
        (homeSections?.DiscoverItems ?? Enumerable.Empty<HomeDiscoverItemDto>())
            .Where(item => activeDiscoveryFilter == "all" || item.FilterKey == activeDiscoveryFilter);


    protected override async Task OnInitializedAsync()
    {
        try
        {
            homeSections = await HomeService.GetHomeSectionsAsync();
            ApplyDynamicHeroFromDb();
        }
        catch { /* silently fail if DB not available */ }
        finally { sectionsLoading = false; }
    }

    protected override void OnInitialized()
    {
        heroSlides = new List<HeroSlide>
        {
            new HeroSlide
            {
                Image = "https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=1600&q=80",
                Badge = "مدرسه آنلاین",
                Title = "مسیر یادگیری خودت را همین امروز شروع کن",
                Description = "از دوره‌های جدید دیدن کن و چالش روزانه را انجام بده تا امتیاز بگیری.",
                PrimaryLabel = "ورود به مدرسه",
                PrimaryLink = "/school",
                SecondaryLabel = "مشاهده پروفایل",
                SecondaryLink = "/profile",
                Stat1 = "120K+",
                Stat1Label = "دانش‌آموز",
                Stat2 = "2,400+",
                Stat2Label = "دوره فعال"
            },
            new HeroSlide
            {
                Image = "https://images.unsplash.com/photo-1516116216624-53e697900ea0?w=1600&q=80",
                Badge = "فروشگاه",
                Title = "محصولات محبوب فروشگاه را ببین",
                Description = "بهترین محصولات هفته و ماه مستقیماً از فروشگاه نمایش داده می‌شوند.",
                PrimaryLabel = "رفتن به فروشگاه",
                PrimaryLink = "/store",
                SecondaryLabel = "جزئیات بیشتر",
                SecondaryLink = "/store",
                Stat1 = "300+",
                Stat1Label = "محصول",
                Stat2 = "روزانه",
                Stat2Label = "به‌روزرسانی"
            }
        };
    }

    private void ApplyDynamicHeroFromDb()
    {
        if (homeSections?.HeroBanners == null || !homeSections.HeroBanners.Any())
        {
            return;
        }

        heroSlides = homeSections.HeroBanners.Select(b => new HeroSlide
        {
            Image = b.ImageUrl,
            Badge = b.Badge,
            Title = b.Title,
            Description = b.Description,
            PrimaryLabel = b.PrimaryLabel,
            PrimaryLink = b.PrimaryLink,
            SecondaryLabel = b.SecondaryLabel,
            SecondaryLink = b.SecondaryLink,
            Stat1 = b.Stat1,
            Stat1Label = b.Stat1Label,
            Stat2 = b.Stat2,
            Stat2Label = b.Stat2Label
        }).ToList();

        heroIndex = 0;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _carouselTimer = new System.Threading.Timer(_ =>
            {
                InvokeAsync(() =>
                {
                    heroIndex = (heroIndex + 1) % heroSlides.Count;
                    StateHasChanged();
                });
            }, null, 5000, 5000);
        }
    }

    private void NextHero()
    {
        if (heroSlides.Count == 0) return;
        heroIndex = (heroIndex + 1) % heroSlides.Count;
    }

    private void PrevHero()
    {
        if (heroSlides.Count == 0) return;
        heroIndex = (heroIndex - 1 + heroSlides.Count) % heroSlides.Count;
    }

    private void SetHeroSlide(int i)
    {
        if (heroSlides.Count == 0) return;
        heroIndex = Math.Clamp(i, 0, heroSlides.Count - 1);
    }
    private void SetDiscoveryFilter(string key)
    {
        activeDiscoveryFilter = key;
    }

    private static string ResolveImage(string? imageUrl, string? sourceType)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
        {
            return sourceType?.ToLowerInvariant() switch
            {
                "course" => "https://images.unsplash.com/photo-1434030216411-0b793f4b6f97?w=1200&q=80",
                "content" => "https://images.unsplash.com/photo-1516116216624-53e697900ea0?w=1200&q=80",
                _ => "https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=1200&q=80"
            };
        }

        var normalized = imageUrl.Trim();
        if (normalized.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            normalized.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
            normalized.StartsWith("data:", StringComparison.OrdinalIgnoreCase))
        {
            return normalized;
        }

        return normalized.StartsWith('/') ? normalized : $"/{normalized}";
    }

    private static string FixMojibake(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        if (!value.Contains('Ø') && !value.Contains('Ù') && !value.Contains('â') && !value.Contains('ð'))
        {
            return value;
        }

        try
        {
            var bytes = Encoding.Latin1.GetBytes(value);
            return Encoding.UTF8.GetString(bytes);
        }
        catch
        {
            return value;
        }
    }


    public void Dispose() { _carouselTimer?.Dispose(); }
}
