@page "/"
@rendermode InteractiveServer
@using System.Text.Json
@using Avina.Models
@using Avina.Services
@inject AuthStateService AuthState
@inject IGrowthEngineService GrowthEngineService
@inject IJSRuntime JS

<style>
    /* ========= Growth Dashboard - رشد جذاب نوجوان ========= */
    .growth-dashboard {
        max-width: 1400px;
        margin: 0 auto;
        padding: 1.5rem 1.25rem 3rem;
        display: grid;
        gap: 1.25rem;
        position: relative;
    }

    /* Hero با sidebar accent در دسکتاپ */
    @@media (min-width: 1100px) {
        .hero-card {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 320px;
            gap: 1.5rem;
        }
        .hero-card > .hero-content,
        .hero-card > .xp-section {
            grid-column: 1;
        }
        .hero-side-accent {
            grid-column: 2;
            grid-row: 1 / 3;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            justify-content: center;
            position: relative;
        }
    }
    .hero-side-accent { display: none; }
    @@media (min-width: 1100px) { .hero-side-accent { display: flex; } }

    .accent-pill {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 0.85rem 1rem;
        background: linear-gradient(135deg, rgba(255, 215, 140, 0.10), rgba(180, 150, 255, 0.10));
        border: 1px solid rgba(255, 215, 140, 0.25);
        border-radius: 0.95rem;
        backdrop-filter: blur(10px);
        animation: pillFloat 5s ease-in-out infinite;
    }
    .accent-pill:nth-child(2) { animation-delay: -1.5s; }
    .accent-pill:nth-child(3) { animation-delay: -3s; }

    @@keyframes pillFloat {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-3px); }
    }

    .accent-pill-icon {
        flex-shrink: 0;
        width: 44px; height: 44px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--pill-grad, #ffd78c), var(--pill-grad-end, #ff9a55));
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
    }
    .accent-pill-tip { display:flex; flex-direction:column; gap:0.15rem; min-width:0; }
    .accent-pill-tip .tip-title { font-weight: 800; color: #fff; font-size: 0.92rem; }
    .accent-pill-tip .tip-desc { color: #c1cde0; font-size: 0.78rem; line-height: 1.5; }

    /* Hero card - بزرگ، gradient، Welcome */
    .hero-card {
        position: relative;
        background:
            radial-gradient(circle at 0% 0%, rgba(255, 215, 140, 0.18), transparent 35%),
            radial-gradient(circle at 100% 100%, rgba(180, 150, 255, 0.20), transparent 40%),
            linear-gradient(135deg, #1a1f3a 0%, #2d1f50 50%, #1a1f3a 100%);
        border: 1px solid rgba(170, 199, 255, 0.18);
        border-radius: 1.5rem;
        padding: 1.75rem 1.5rem 1.5rem;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(76, 29, 149, 0.25), 0 4px 20px rgba(0, 0, 0, 0.3);
    }

    .hero-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(ellipse 50% 40% at 90% 0%, rgba(255, 215, 140, 0.10), transparent),
            radial-gradient(ellipse 60% 50% at 0% 100%, rgba(170, 199, 255, 0.08), transparent);
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 1.25rem;
        align-items: center;
    }

    .hero-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: linear-gradient(135deg, #ffd78c 0%, #ff9a55 50%, #b496ff 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        box-shadow: 0 8px 32px rgba(255, 154, 85, 0.4), inset 0 -2px 8px rgba(0,0,0,0.2);
        position: relative;
        animation: avatarFloat 4s ease-in-out infinite;
    }

    .hero-avatar::after {
        content: '';
        position: absolute;
        inset: -4px;
        border-radius: 50%;
        background: conic-gradient(from 0deg, #ffd78c, #aac7ff, #b496ff, #ffd78c);
        z-index: -1;
        animation: ringRotate 8s linear infinite;
        opacity: 0.6;
    }

    @@keyframes avatarFloat {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-4px); }
    }

    @@keyframes ringRotate {
        to { transform: rotate(360deg); }
    }

    .hero-text {
        display: grid;
        gap: 0.4rem;
    }

    .hero-greeting {
        font-size: 0.85rem;
        color: #ffd78c;
        font-weight: 700;
        letter-spacing: 0.5px;
        margin: 0;
    }

    .hero-name {
        font-size: 1.65rem;
        font-weight: 900;
        margin: 0;
        background: linear-gradient(90deg, #fff 0%, #d4c5ff 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-tagline {
        margin: 0;
        color: rgba(225, 220, 255, 0.85);
        font-size: 0.95rem;
        line-height: 1.7;
    }

    /* XP Bar */
    .xp-section {
        margin-top: 1.25rem;
        position: relative;
        z-index: 1;
    }

    .xp-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.82rem;
        color: #cdc7ff;
        margin-bottom: 0.5rem;
        font-weight: 700;
    }

    .xp-row .level-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: linear-gradient(135deg, #ffd78c, #ff9a55);
        color: #2a1a00;
        padding: 0.2rem 0.7rem;
        border-radius: 999px;
        font-weight: 900;
        box-shadow: 0 2px 8px rgba(255, 154, 85, 0.3);
    }

    .xp-bar {
        height: 12px;
        background: rgba(15, 18, 35, 0.6);
        border: 1px solid rgba(170, 199, 255, 0.2);
        border-radius: 999px;
        overflow: hidden;
        position: relative;
    }

    .xp-fill {
        height: 100%;
        background: linear-gradient(90deg, #aac7ff 0%, #b496ff 50%, #ffd78c 100%);
        border-radius: 999px;
        position: relative;
        transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 0 12px rgba(180, 150, 255, 0.6);
    }

    .xp-fill::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
        animation: xpShimmer 2.5s ease-in-out infinite;
    }

    @@keyframes xpShimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(200%); }
    }

    /* Stats grid */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.85rem;
    }

    .stat-card {
        position: relative;
        background: linear-gradient(135deg, rgba(28, 32, 60, 0.85), rgba(20, 24, 45, 0.85));
        border: 1px solid rgba(170, 199, 255, 0.15);
        border-radius: 1rem;
        padding: 1rem;
        backdrop-filter: blur(10px);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: var(--accent, linear-gradient(90deg, #aac7ff, #b496ff));
        opacity: 0.7;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        border-color: rgba(255, 215, 140, 0.4);
        box-shadow: 0 12px 32px rgba(76, 29, 149, 0.35);
    }

    .stat-card.path     { --accent: linear-gradient(90deg, #aac7ff, #6c8aff); }
    .stat-card.skill    { --accent: linear-gradient(90deg, #b496ff, #d4a5ff); }
    .stat-card.level    { --accent: linear-gradient(90deg, #ffd78c, #ff9a55); }
    .stat-card.xp       { --accent: linear-gradient(90deg, #7dd3a8, #aac7ff); }
    .stat-card.coin     { --accent: linear-gradient(90deg, #ffb68c, #ffd78c); }
    .stat-card.streak   { --accent: linear-gradient(90deg, #ff7e7e, #ffb68c); }

    .stat-card .stat-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        background: rgba(170, 199, 255, 0.1);
        margin-bottom: 0.5rem;
    }

    .stat-card .stat-label {
        font-size: 0.78rem;
        color: #a8b3d4;
        margin-bottom: 0.25rem;
        display: block;
        font-weight: 600;
    }

    .stat-card .stat-value {
        font-weight: 900;
        color: #f5f3ff;
        font-size: 1.1rem;
        line-height: 1.3;
    }

    .stat-card .stat-sub {
        display: block;
        font-size: 0.72rem;
        color: #8a92b3;
        margin-top: 0.2rem;
        font-weight: 600;
    }

    /* Mission Card - the star of the show */
    .mission-card {
        position: relative;
        background:
            radial-gradient(circle at 100% 0%, rgba(255, 215, 140, 0.22), transparent 50%),
            linear-gradient(135deg, #232450 0%, #1a1f3a 100%);
        border: 1px solid rgba(255, 215, 140, 0.25);
        border-radius: 1.5rem;
        padding: 1.5rem;
        box-shadow: 0 16px 48px rgba(255, 154, 85, 0.12), 0 4px 16px rgba(0,0,0,0.3);
        overflow: hidden;
    }

    .mission-card::before {
        content: '';
        position: absolute;
        top: -50%; right: -50%;
        width: 300px; height: 300px;
        background: radial-gradient(circle, rgba(255, 215, 140, 0.08), transparent 60%);
        animation: missionGlow 6s ease-in-out infinite;
    }

    @@keyframes missionGlow {
        0%, 100% { transform: scale(1); opacity: 0.7; }
        50% { transform: scale(1.15); opacity: 1; }
    }

    .mission-header {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-start;
        gap: 0.85rem;
        margin-bottom: 1rem;
    }

    .mission-icon {
        flex-shrink: 0;
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, #ffd78c, #ff9a55);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        box-shadow: 0 8px 24px rgba(255, 154, 85, 0.45);
        animation: iconPulse 2.4s ease-in-out infinite;
    }

    @@keyframes iconPulse {
        0%, 100% { transform: scale(1); box-shadow: 0 8px 24px rgba(255, 154, 85, 0.45); }
        50% { transform: scale(1.06); box-shadow: 0 8px 32px rgba(255, 154, 85, 0.65); }
    }

    .mission-eyebrow {
        font-size: 0.78rem;
        font-weight: 800;
        color: #ffd78c;
        letter-spacing: 0.5px;
        margin: 0 0 0.35rem 0;
    }

    .mission-title {
        margin: 0;
        font-size: 1.35rem;
        font-weight: 900;
        color: #ffffff;
        line-height: 1.3;
    }

    .mission-desc {
        margin: 0 0 1rem 0;
        color: #d4d8f5;
        line-height: 1.85;
        font-size: 0.95rem;
        position: relative;
        z-index: 1;
    }

    .mission-meta {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
        margin-bottom: 1rem;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        background: rgba(15, 18, 35, 0.6);
        border: 1px solid rgba(170, 199, 255, 0.2);
        color: #d4d8f5;
        border-radius: 999px;
        padding: 0.4rem 0.85rem;
        font-size: 0.78rem;
        font-weight: 700;
        backdrop-filter: blur(8px);
        transition: all 0.2s;
    }

    .chip:hover {
        border-color: rgba(255, 215, 140, 0.5);
        transform: translateY(-1px);
    }

    .chip-time   { color: #aac7ff; border-color: rgba(170, 199, 255, 0.35); }
    .chip-diff   { color: #ff9a9a; border-color: rgba(255, 154, 154, 0.35); }
    .chip-xp     { color: #7dd3a8; border-color: rgba(125, 211, 168, 0.35); }
    .chip-coin   { color: #ffd78c; border-color: rgba(255, 215, 140, 0.45); }
    .chip-path   { color: #b496ff; border-color: rgba(180, 150, 255, 0.35); }
    .chip-skill  { color: #d4a5ff; border-color: rgba(212, 165, 255, 0.35); }

    .mission-reason {
        position: relative;
        z-index: 1;
        background: rgba(125, 211, 168, 0.10);
        border-right: 3px solid #7dd3a8;
        border-radius: 0.75rem;
        padding: 0.75rem 0.95rem;
        color: #b8e8c8;
        font-size: 0.88rem;
        line-height: 1.7;
        margin-bottom: 1rem;
    }

    .action-row {
        display: flex;
        gap: 0.65rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
    }

    .btn-main {
        border: none;
        border-radius: 0.85rem;
        background: linear-gradient(135deg, #ffd78c 0%, #ff9a55 100%);
        color: #2a1500;
        padding: 0.75rem 1.5rem;
        font-weight: 900;
        font-size: 0.92rem;
        cursor: pointer;
        font-family: inherit;
        box-shadow: 0 8px 24px rgba(255, 154, 85, 0.35);
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        text-decoration: none;
    }

    .btn-main:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(255, 154, 85, 0.55);
    }

    .btn-main:active { transform: translateY(0); }
    .btn-main:disabled { opacity: 0.6; cursor: not-allowed; }

    .btn-alt {
        border: 1px solid rgba(170, 199, 255, 0.3);
        border-radius: 0.85rem;
        background: rgba(28, 32, 60, 0.5);
        color: #d4d8f5;
        padding: 0.75rem 1.25rem;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        font-family: inherit;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: all 0.2s;
        backdrop-filter: blur(8px);
    }

    .btn-alt:hover {
        border-color: rgba(255, 215, 140, 0.5);
        background: rgba(255, 215, 140, 0.08);
        color: #ffd78c;
    }

    .submit-panel {
        position: relative;
        z-index: 1;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px dashed rgba(170, 199, 255, 0.2);
        display: grid;
        gap: 0.65rem;
    }

    .input {
        width: 100%;
        border: 1px solid rgba(170, 199, 255, 0.2);
        border-radius: 0.85rem;
        background: rgba(15, 18, 35, 0.7);
        color: #f1f5ff;
        padding: 0.75rem 0.95rem;
        font-size: 0.92rem;
        box-sizing: border-box;
        font-family: inherit;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .input:focus {
        outline: none;
        border-color: #ffd78c;
        box-shadow: 0 0 0 3px rgba(255, 215, 140, 0.15);
    }

    .notice {
        border-radius: 0.85rem;
        padding: 0.75rem 1rem;
        font-size: 0.88rem;
        border: 1px solid;
        line-height: 1.7;
    }

    .notice.ok    { background: rgba(125, 211, 168, 0.12); border-color: rgba(125, 211, 168, 0.4); color: #b8e8c8; }
    .notice.warn  { background: rgba(255, 183, 77, 0.12); border-color: rgba(255, 183, 77, 0.4);  color: #ffd78c; }

    /* Empty state - login required */
    .empty-hero {
        text-align: center;
        padding: 3rem 1.5rem;
    }

    .empty-hero .empty-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
        animation: avatarFloat 4s ease-in-out infinite;
    }

    .empty-hero h1 {
        font-size: 1.75rem;
        font-weight: 900;
        margin: 0 0 0.75rem 0;
        background: linear-gradient(90deg, #aac7ff, #b496ff, #ffd78c);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .empty-hero p {
        color: #c1cde0;
        margin: 0 0 1.5rem 0;
        font-size: 1rem;
        line-height: 1.8;
    }

    /* Loading skeleton */
    .skeleton-wrap {
        text-align: center;
        padding: 3rem 1rem;
    }

    .skeleton-orb {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        margin: 0 auto 1rem;
        background: linear-gradient(135deg, #aac7ff, #b496ff, #ffd78c);
        animation: orbPulse 1.4s ease-in-out infinite;
        box-shadow: 0 0 32px rgba(180, 150, 255, 0.4);
    }

    @@keyframes orbPulse {
        0%, 100% { transform: scale(1); opacity: 0.85; }
        50% { transform: scale(1.15); opacity: 1; }
    }

    .skeleton-wrap p {
        color: #b8c0e0;
        margin: 0;
    }

    /* Animations for entrance */
    .animate-page {
        animation: fadeUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) both;
    }
    .animate-page.delay-1 { animation-delay: 0.1s; }
    .animate-page.delay-2 { animation-delay: 0.2s; }
    .animate-page.delay-3 { animation-delay: 0.3s; }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 600px) {
        .hero-content { grid-template-columns: 1fr; text-align: center; justify-items: center; }
        .hero-name { font-size: 1.4rem; }
        .mission-title { font-size: 1.15rem; }
    }
</style>

<div class="growth-dashboard">
    @if (!AuthState.IsLoggedIn || AuthState.CurrentUser is null)
    {
        <section class="hero-card animate-page">
            <div class="empty-hero">
                <div class="empty-icon">🌟</div>
                <h1>به آخرین نگهبان خوش آمدی</h1>
                <p>هر روز یک قدم کوچک، اما واقعی در مسیر رشد.<br />برای دیدن ماموریت امروزت، وارد حساب شو.</p>
                <a class="btn-main" href="/login">
                    <span>شروع سفر</span>
                    <span>←</span>
                </a>
            </div>
        </section>
    }
    else if (isLoading)
    {
        <section class="hero-card animate-page">
            <div class="skeleton-wrap">
                <div class="skeleton-orb"></div>
                <p>در حال خواندن مسیر و ماموریت امروزت...</p>
            </div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <section class="hero-card animate-page">
            <div class="hero-content">
                <div class="hero-avatar">⚠️</div>
                <div class="hero-text">
                    <h1 class="hero-name">یک خطا رخ داد</h1>
                    <p class="hero-tagline">بعد از رفع، دوباره امتحان کن.</p>
                </div>
            </div>
            <div class="notice warn" style="margin-top:1rem;">@errorMessage</div>
        </section>
    }
    else if (dashboard is not null)
    {
        var totalXp = dashboard.XP + dashboard.XPToNextLevel;
        var xpPercent = totalXp > 0 ? (int)((double)dashboard.XP / totalXp * 100) : 0;
        if (xpPercent < 4 && dashboard.XP > 0) { xpPercent = 4; }
        if (xpPercent > 100) { xpPercent = 100; }
        var greetingHour = DateTime.Now.Hour;
        var greeting = greetingHour < 12 ? "صبح بخیر" : greetingHour < 17 ? "ظهر بخیر" : greetingHour < 21 ? "عصر بخیر" : "شب بخیر";
        var firstChar = string.IsNullOrWhiteSpace(dashboard.UserName) ? "🙂" : dashboard.UserName.Trim().Substring(0, 1);

        <!-- ===== Hero Card ===== -->
        <section class="hero-card animate-page">
            <div class="hero-content">
                <div class="hero-avatar">@firstChar</div>
                <div class="hero-text">
                    <p class="hero-greeting">⭐ @greeting، نگهبان</p>
                    <h1 class="hero-name">@dashboard.UserName</h1>
                    <p class="hero-tagline">امروز فقط یک قدم. کوچک، اما واقعی.</p>
                </div>
            </div>

            <div class="xp-section">
                <div class="xp-row">
                    <span><span class="level-badge">⚡ سطح @dashboard.Level</span></span>
                    <span>@dashboard.XP / @totalXp XP — تا سطح بعد @dashboard.XPToNextLevel</span>
                </div>
                <div class="xp-bar">
                    <div class="xp-fill" style="width:@(xpPercent)%;"></div>
                </div>
            </div>
        </section>

        <!-- ===== Stats Grid ===== -->
        <div class="stats-grid animate-page delay-1">
            <div class="stat-card path">
                <div class="stat-icon">🧭</div>
                <span class="stat-label">مسیر فعال</span>
                <span class="stat-value">@dashboard.ActivePath</span>
            </div>
            <div class="stat-card skill">
                <div class="stat-icon">🎯</div>
                <span class="stat-label">مهارت فعلی</span>
                <span class="stat-value">@dashboard.CurrentSkill</span>
            </div>
            <div class="stat-card coin">
                <div class="stat-icon">🪙</div>
                <span class="stat-label">کوین</span>
                <span class="stat-value">@dashboard.Coin</span>
                <span class="stat-sub">قابل استفاده در فروشگاه</span>
            </div>
            <div class="stat-card streak">
                <div class="stat-icon">🔥</div>
                <span class="stat-label">رکورد روزانه</span>
                <span class="stat-value">@dashboard.DailyStreak روز</span>
                <span class="stat-sub">ادامه بده تا نشکنه</span>
            </div>
        </div>

        @if (dashboard.NeedsOnboarding)
        {
            <section class="mission-card animate-page delay-2">
                <div class="mission-header">
                    <div class="mission-icon">🧬</div>
                    <div>
                        <p class="mission-eyebrow">آغاز سفر</p>
                        <h2 class="mission-title">آزمون شناخت اولیه</h2>
                    </div>
                </div>
                <p class="mission-desc">با یک آزمون کوتاه سناریومحور (بدون نمره، بدون قضاوت) ما تو رو می‌شناسیم تا اولین ماموریت دقیقاً برای تو باشه.</p>
                <div class="action-row">
                    <a class="btn-main" href="/onboarding">
                        <span>🚀</span>
                        <span>شروع آزمون</span>
                    </a>
                </div>
            </section>
        }
        else if (dashboard.TodayMission is not null)
        {
            <section class="mission-card animate-page delay-2">
                <div class="mission-header">
                    <div class="mission-icon">⚡</div>
                    <div>
                        <p class="mission-eyebrow">ماموریت امروز تو</p>
                        <h2 class="mission-title">@dashboard.TodayMission.MissionTitle</h2>
                    </div>
                </div>

                <p class="mission-desc">@dashboard.TodayMission.MissionDescription</p>

                <div class="mission-meta">
                    <span class="chip chip-time">⏱️ @dashboard.TodayMission.EstimatedTime دقیقه</span>
                    <span class="chip chip-diff">🎲 سختی @dashboard.TodayMission.Difficulty</span>
                    <span class="chip chip-xp">⚡ @dashboard.TodayMission.RewardXP XP</span>
                    <span class="chip chip-coin">🪙 @dashboard.TodayMission.RewardCoin کوین</span>
                    <span class="chip chip-path">🧭 @dashboard.TodayMission.ConnectedPath</span>
                    <span class="chip chip-skill">🎯 @dashboard.TodayMission.ConnectedSkill</span>
                </div>

                <div class="mission-reason">💡 @dashboard.TodayMission.ReasonForRecommendation</div>

                <div class="action-row">
                    <button class="btn-main" @onclick="ToggleSubmitPanel">
                        <span>@(showSubmitPanel ? "بستن" : "شروع کن")</span>
                        <span>@(showSubmitPanel ? "▾" : "←")</span>
                    </button>
                    <a class="btn-alt" href="/onboarding">
                        <span>🔄</span>
                        <span>اجرای دوباره آزمون</span>
                    </a>
                </div>

                @if (showSubmitPanel)
                {
                    <div class="submit-panel">
                        <textarea class="input" rows="4" placeholder="🖋️ نتیجه ماموریتت رو در چند جمله بنویس..." @bind="textAnswer"></textarea>
                        <input class="input" placeholder="🔗 لینک تصویر/ویدیو (اختیاری)" @bind="mediaUrl" />
                        <div class="action-row">
                            <button class="btn-main" @onclick="SubmitMissionAsync" disabled="@isSubmitting">
                                <span>@(isSubmitting ? "⏳" : "✅")</span>
                                <span>@(isSubmitting ? "در حال ثبت..." : "ثبت ماموریت")</span>
                            </button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(submitMessage))
                        {
                            <div class="notice @(submitWasSuccess ? "ok" : "warn")">@submitMessage</div>
                        }
                    </div>
                }
            </section>
        }
    }
</div>

@code {
    private const string StorageKey = "avina_user";
    private DashboardDto? dashboard;
    private bool isLoading = true;
    private bool showSubmitPanel;
    private bool isSubmitting;
    private string textAnswer = string.Empty;
    private string mediaUrl = string.Empty;
    private string submitMessage = string.Empty;
    private bool submitWasSuccess;
    private string errorMessage = string.Empty;

    protected override void OnInitialized()
    {
        AuthState.StateChanged += OnAuthStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RestoreUserFromStorageAsync();
            await LoadDashboardAsync();
        }
    }

    private async Task OnAuthStateChanged()
    {
        await LoadDashboardAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RestoreUserFromStorageAsync()
    {
        if (AuthState.IsLoggedIn)
        {
            return;
        }

        try
        {
            var json = await JS.InvokeAsync<string?>("lsGet", StorageKey);
            if (string.IsNullOrWhiteSpace(json))
            {
                return;
            }

            var user = JsonSerializer.Deserialize<UserCacheDto>(json);
            if (user is not null)
            {
                AuthState.SetUser(user);
            }
        }
        catch
        {
            // Ignore malformed local storage state.
        }
    }

    private async Task LoadDashboardAsync()
    {
        submitMessage = string.Empty;
        errorMessage = string.Empty;
        isLoading = true;
        await InvokeAsync(StateHasChanged);

        if (!AuthState.IsLoggedIn || AuthState.CurrentUser is null)
        {
            dashboard = null;
            isLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            dashboard = await GrowthEngineService.GetDashboardAsync(AuthState.CurrentUser.Id);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleSubmitPanel()
    {
        showSubmitPanel = !showSubmitPanel;
        submitMessage = string.Empty;
    }

    private async Task SubmitMissionAsync()
    {
        if (dashboard?.TodayMission is null || AuthState.CurrentUser is null)
        {
            return;
        }

        isSubmitting = true;
        submitMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = await GrowthEngineService.SubmitMissionAsync(
                AuthState.CurrentUser.Id,
                dashboard.TodayMission.MissionId,
                textAnswer,
                mediaUrl);

            submitWasSuccess = result.Status is MissionSubmissionStatus.AutoApproved or MissionSubmissionStatus.Approved;
            submitMessage = $"{result.Message} (وضعیت: {ToSubmissionStatusFa(result.Status)}، امتیاز تجربه: {result.GrantedXP}، کوین: {result.GrantedCoin})";

            textAnswer = string.Empty;
            mediaUrl = string.Empty;
            await LoadDashboardAsync();
        }
        catch (Exception ex)
        {
            submitWasSuccess = false;
            submitMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string ToSubmissionStatusFa(MissionSubmissionStatus status) => status switch
    {
        MissionSubmissionStatus.Pending => "در انتظار بررسی",
        MissionSubmissionStatus.Approved => "تاییدشده",
        MissionSubmissionStatus.Rejected => "ردشده",
        MissionSubmissionStatus.AutoApproved => "تایید خودکار",
        _ => "نامشخص"
    };

    public void Dispose()
    {
        AuthState.StateChanged -= OnAuthStateChanged;
    }
}
