@page "/"
@rendermode InteractiveServer
@using System.Text.Json
@using Avina.Models
@using Avina.Services
@inject AuthStateService AuthState
@inject IGrowthEngineService GrowthEngineService
@inject IJSRuntime JS

<style>
    .growth-dashboard {
        max-width: 1080px;
        margin: 0 auto;
        padding: 2rem 1.25rem 2.5rem;
        display: grid;
        gap: 1rem;
    }

    .surface {
        background: #171c24;
        border: 1px solid #2d3747;
        border-radius: 10px;
    }

    .header-band {
        padding: 1.2rem 1.2rem 1.1rem;
        display: grid;
        gap: 0.5rem;
    }

    .header-band h1 {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 800;
        color: #eef3ff;
    }

    .header-band p {
        margin: 0;
        color: #aab7cd;
        font-size: 0.92rem;
    }

    .metrics {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
        gap: 0.65rem;
        padding: 0 1rem 1rem;
    }

    .metric {
        background: #111620;
        border: 1px solid #2d3747;
        border-radius: 8px;
        padding: 0.65rem 0.7rem;
        min-height: 76px;
    }

    .metric .label {
        font-size: 0.74rem;
        color: #8ea0c0;
        margin-bottom: 0.25rem;
        display: block;
    }

    .metric .value {
        font-weight: 800;
        color: #f2f6ff;
        font-size: 0.96rem;
        line-height: 1.35;
    }

    .mission-panel {
        padding: 1rem;
        display: grid;
        gap: 0.8rem;
    }

    .mission-title {
        margin: 0;
        font-size: 1.1rem;
        color: #f3f7ff;
        font-weight: 800;
    }

    .mission-desc {
        margin: 0;
        color: #c1cde0;
        line-height: 1.75;
        font-size: 0.9rem;
    }

    .mission-meta {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .chip {
        background: #111620;
        border: 1px solid #334159;
        color: #b8c8e5;
        border-radius: 999px;
        padding: 0.3rem 0.65rem;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .action-row {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
    }

    .btn-main {
        border: none;
        border-radius: 8px;
        background: #3578f6;
        color: #fff;
        padding: 0.55rem 0.95rem;
        font-weight: 700;
        font-size: 0.84rem;
        cursor: pointer;
    }

    .btn-main:disabled {
        opacity: 0.65;
        cursor: not-allowed;
    }

    .btn-alt {
        border: 1px solid #3a4965;
        border-radius: 8px;
        background: transparent;
        color: #c8d4e8;
        padding: 0.55rem 0.95rem;
        font-weight: 700;
        font-size: 0.84rem;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

    .submit-panel {
        border-top: 1px solid #2b3649;
        padding-top: 0.8rem;
        display: grid;
        gap: 0.55rem;
    }

    .input {
        width: 100%;
        border: 1px solid #34435b;
        border-radius: 8px;
        background: #0f141d;
        color: #f1f5ff;
        padding: 0.6rem 0.7rem;
        font-size: 0.87rem;
        box-sizing: border-box;
    }

    .notice {
        border-radius: 8px;
        padding: 0.6rem 0.75rem;
        font-size: 0.82rem;
        border: 1px solid;
    }

    .notice.ok {
        background: rgba(76, 175, 80, 0.12);
        border-color: rgba(76, 175, 80, 0.32);
        color: #9be5a2;
    }

    .notice.warn {
        background: rgba(255, 183, 77, 0.12);
        border-color: rgba(255, 183, 77, 0.35);
        color: #ffc978;
    }
</style>

<div class="growth-dashboard">
    @if (!AuthState.IsLoggedIn || AuthState.CurrentUser is null)
    {
        <section class="surface header-band animate-page">
            <h1>هسته رشد آخرین نگهبان</h1>
            <p>برای دیدن ماموریت پیشنهادی امروز، ابتدا وارد حساب کاربری شوید.</p>
            <div class="action-row">
                <a class="btn-main" href="/login">ورود</a>
            </div>
        </section>
    }
    else if (isLoading)
    {
        <section class="surface header-band animate-page">
            <h1>در حال بارگذاری داشبورد رشد...</h1>
            <p>در حال خواندن پروفایل، مسیر فعال و ماموریت امروز.</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <section class="surface header-band animate-page">
            <h1>داشبورد رشد</h1>
            <div class="notice warn">@errorMessage</div>
        </section>
    }
    else if (dashboard is not null)
    {
        <section class="surface animate-page">
            <div class="header-band">
                <h1>@dashboard.UserName</h1>
                <p>در صفحه اصلی فقط قدم بعدی رشدت را می‌بینی.</p>
            </div>
            <div class="metrics animate-page delay-1">
                <div class="metric">
                    <span class="label">مسیر فعال</span>
                    <span class="value">@dashboard.ActivePath</span>
                </div>
                <div class="metric">
                    <span class="label">مهارت فعلی</span>
                    <span class="value">@dashboard.CurrentSkill</span>
                </div>
                <div class="metric">
                    <span class="label">سطح</span>
                    <span class="value">@dashboard.Level</span>
                </div>
                <div class="metric">
                    <span class="label">پیشرفت تجربه</span>
                    <span class="value">@dashboard.XP (تا سطح بعد: @dashboard.XPToNextLevel)</span>
                </div>
                <div class="metric">
                    <span class="label">کوین</span>
                    <span class="value">@dashboard.Coin</span>
                </div>
                <div class="metric">
                    <span class="label">رکورد روزانه</span>
                    <span class="value">@dashboard.DailyStreak روز</span>
                </div>
            </div>
        </section>

        @if (dashboard.NeedsOnboarding)
        {
            <section class="surface mission-panel animate-page delay-2">
                <h2 class="mission-title">شروع آزمون اولیه</h2>
                <p class="mission-desc">آزمون سناریومحور را کامل کن تا هسته رشد اولین ماموریتت را پیشنهاد دهد.</p>
                <div class="action-row">
                    <a class="btn-main" href="/onboarding">شروع آزمون</a>
                </div>
            </section>
        }
        else if (dashboard.TodayMission is not null)
        {
            <section class="surface mission-panel animate-page delay-2">
                <h2 class="mission-title">@dashboard.TodayMission.MissionTitle</h2>
                <p class="mission-desc">@dashboard.TodayMission.MissionDescription</p>

                <div class="mission-meta">
                    <span class="chip">@dashboard.TodayMission.EstimatedTime دقیقه</span>
                    <span class="chip">سختی @dashboard.TodayMission.Difficulty</span>
                    <span class="chip">@dashboard.TodayMission.RewardXP امتیاز تجربه</span>
                    <span class="chip">@dashboard.TodayMission.RewardCoin کوین</span>
                    <span class="chip">@dashboard.TodayMission.ConnectedPath</span>
                    <span class="chip">@dashboard.TodayMission.ConnectedSkill</span>
                </div>

                <div class="notice ok">@dashboard.TodayMission.ReasonForRecommendation</div>

                <div class="action-row">
                    <button class="btn-main" @onclick="ToggleSubmitPanel">ادامه</button>
                    <a class="btn-alt" href="/onboarding">اجرای دوباره آزمون</a>
                </div>

                @if (showSubmitPanel)
                {
                    <div class="submit-panel">
                        <textarea class="input" rows="4" placeholder="نتیجه انجام ماموریت را بنویس..." @bind="textAnswer"></textarea>
                        <input class="input" placeholder="لینک رسانه (اختیاری - تصویر/ویدیو)" @bind="mediaUrl" />
                        <div class="action-row">
                            <button class="btn-main" @onclick="SubmitMissionAsync" disabled="@isSubmitting">
                                @(isSubmitting ? "در حال ثبت..." : "ثبت ماموریت")
                            </button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(submitMessage))
                        {
                            <div class="notice @(submitWasSuccess ? "ok" : "warn")">@submitMessage</div>
                        }
                    </div>
                }
            </section>
        }
    }
</div>

@code {
    private const string StorageKey = "avina_user";
    private DashboardDto? dashboard;
    private bool isLoading = true;
    private bool showSubmitPanel;
    private bool isSubmitting;
    private string textAnswer = string.Empty;
    private string mediaUrl = string.Empty;
    private string submitMessage = string.Empty;
    private bool submitWasSuccess;
    private string errorMessage = string.Empty;

    protected override void OnInitialized()
    {
        AuthState.StateChanged += OnAuthStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RestoreUserFromStorageAsync();
            await LoadDashboardAsync();
        }
    }

    private async Task OnAuthStateChanged()
    {
        await LoadDashboardAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RestoreUserFromStorageAsync()
    {
        if (AuthState.IsLoggedIn)
        {
            return;
        }

        try
        {
            var json = await JS.InvokeAsync<string?>("lsGet", StorageKey);
            if (string.IsNullOrWhiteSpace(json))
            {
                return;
            }

            var user = JsonSerializer.Deserialize<UserCacheDto>(json);
            if (user is not null)
            {
                AuthState.SetUser(user);
            }
        }
        catch
        {
            // Ignore malformed local storage state.
        }
    }

    private async Task LoadDashboardAsync()
    {
        submitMessage = string.Empty;
        errorMessage = string.Empty;
        isLoading = true;
        await InvokeAsync(StateHasChanged);

        if (!AuthState.IsLoggedIn || AuthState.CurrentUser is null)
        {
            dashboard = null;
            isLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            dashboard = await GrowthEngineService.GetDashboardAsync(AuthState.CurrentUser.Id);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleSubmitPanel()
    {
        showSubmitPanel = !showSubmitPanel;
        submitMessage = string.Empty;
    }

    private async Task SubmitMissionAsync()
    {
        if (dashboard?.TodayMission is null || AuthState.CurrentUser is null)
        {
            return;
        }

        isSubmitting = true;
        submitMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = await GrowthEngineService.SubmitMissionAsync(
                AuthState.CurrentUser.Id,
                dashboard.TodayMission.MissionId,
                textAnswer,
                mediaUrl);

            submitWasSuccess = result.Status is MissionSubmissionStatus.AutoApproved or MissionSubmissionStatus.Approved;
            submitMessage = $"{result.Message} (وضعیت: {ToSubmissionStatusFa(result.Status)}، امتیاز تجربه: {result.GrantedXP}، کوین: {result.GrantedCoin})";

            textAnswer = string.Empty;
            mediaUrl = string.Empty;
            await LoadDashboardAsync();
        }
        catch (Exception ex)
        {
            submitWasSuccess = false;
            submitMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string ToSubmissionStatusFa(MissionSubmissionStatus status) => status switch
    {
        MissionSubmissionStatus.Pending => "در انتظار بررسی",
        MissionSubmissionStatus.Approved => "تاییدشده",
        MissionSubmissionStatus.Rejected => "ردشده",
        MissionSubmissionStatus.AutoApproved => "تایید خودکار",
        _ => "نامشخص"
    };

    public void Dispose()
    {
        AuthState.StateChanged -= OnAuthStateChanged;
    }
}
