    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _carouselTimer = new System.Threading.Timer(_ =>
            {
                InvokeAsync(() =>
                {
                    heroIndex = (heroIndex + 1) % heroSlides.Count;
                    StateHasChanged();
                });
            }, null, 5000, 5000);
        }
    }

    private void NextHero() { heroIndex = (heroIndex + 1) % heroSlides.Count; }
    private void PrevHero() { heroIndex = (heroIndex - 1 + heroSlides.Count) % heroSlides.Count; }
    private void SetHeroSlide(int i) { heroIndex = i; }

    public void Dispose() { _carouselTimer?.Dispose(); }
