@page "/games"
@rendermode InteractiveServer

<div class="container mt-5">
    <!-- Header -->
    <section class="mb-5">
        <h1 class="display-5 fw-bold mb-3">بازی‌های آموزشی</h1>
        <p class="lead text-muted">یادگیری از طریق بازی و رقابت سالم</p>
    </section>

    <!-- Featured Games -->
    <section class="mb-5">
        <h3 class="mb-4">بازی‌های پیشنهادی</h3>
        <div class="row g-4">
            @foreach (var game in featuredGames)
            {
                <div class="col-lg-4">
                    <div class="game-card rounded-4 overflow-hidden shadow-sm h-100">
                        <img src="@game.Image" alt="@game.Title" style="width: 100%; height: 200px; object-fit: cover;">
                        <div class="p-4">
                            <h5 class="fw-bold mb-2">@game.Title</h5>
                            <p class="text-muted mb-3">@game.Description</p>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-info">@game.Category</span>
                                <small>⭐ @game.Rating.ToString("F1")</small>
                            </div>
                            <button class="btn btn-primary w-100" @onclick="() => PlayGame(game.Id)">شروع بازی</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Leaderboard -->
    <section class="mb-5">
        <h3 class="mb-4">جدول رتبه‌بندی</h3>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>رتبه</th>
                        <th>بازیکن</th>
                        <th>امتیاز</th>
                        <th>بازی</th>
                        <th>زمان</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < leaderboard.Count; i++)
                    {
                        <tr>
                            <td><strong>@(i + 1)</strong></td>
                            <td>@leaderboard[i].PlayerName</td>
                            <td class="text-success fw-bold">@leaderboard[i].Score.ToString("N0")</td>
                            <td>@leaderboard[i].GameName</td>
                            <td>@leaderboard[i].PlayedAt.ToString("g")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <!-- Categories -->
    <section>
        <h3 class="mb-4">دسته‌بندی بازی‌ها</h3>
        <div class="row g-4">
            @foreach (var category in gameCategories)
            {
                <div class="col-md-6 col-lg-3">
                    <div class="category-card p-4 rounded-4 border text-center" style="cursor: pointer;" @onclick="() => FilterByCategory(category.Name)">
                        <div style="font-size: 2.5rem; margin-bottom: 1rem;">@category.Icon</div>
                        <h6 class="fw-bold mb-2">@category.Name</h6>
                        <small class="text-muted">@category.Count بازی</small>
                    </div>
                </div>
            }
        </div>
    </section>
</div>

