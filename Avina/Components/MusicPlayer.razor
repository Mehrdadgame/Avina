@implements IDisposable

<style>
.music-player {
    position: fixed;
    bottom: 0;
    right: 0;
    left: 260px;
    height: 90px;
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    border-top: 1px solid #334155;
    display: flex;
    align-items: center;
    padding: 1rem;
    gap: 1.5rem;
    z-index: 50;
    box-shadow: 0 -5px 20px rgba(0, 0, 0, 0.3);
}

.player-thumbnail {
    width: 60px;
    height: 60px;
    border-radius: 0.5rem;
    background: linear-gradient(135deg, #7c3aed, #ec4899);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
}

.player-info {
    flex: 1;
    min-width: 0;
}

.player-title {
    color: #f1f5f9;
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.player-artist {
    color: #94a3b8;
    font-size: 0.8rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.player-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.player-progress {
    width: 150px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.time-text {
    color: #94a3b8;
    font-size: 0.75rem;
    min-width: 25px;
}

.progress-bar {
    flex: 1;
    height: 3px;
    background-color: #334155;
    border-radius: 2px;
    cursor: pointer;
    position: relative;
}

.progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #7c3aed, #ec4899);
    border-radius: 2px;
    transition: width 0.1s;
}

.control-btn {
    background: none;
    border: none;
    color: #a78bfa;
    font-size: 1.2rem;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 0.5rem;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
}

.control-btn:hover {
    color: #f472b6;
    background-color: rgba(124, 58, 237, 0.2);
}

.control-btn.play {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #7c3aed, #ec4899);
    color: white;
    font-size: 1rem;
}

.control-btn.play:hover {
    transform: scale(1.05);
    background: linear-gradient(135deg, #6d28d9, #db2777);
}

.volume-control {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.volume-slider {
    width: 80px;
    height: 3px;
    background-color: #334155;
    border-radius: 2px;
    cursor: pointer;
}

.close-player {
    background: none;
    border: none;
    color: #94a3b8;
    font-size: 1rem;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 0.5rem;
    transition: all 0.3s ease;
}

.close-player:hover {
    color: #f472b6;
    background-color: rgba(124, 58, 237, 0.2);
}
</style>

@if (isPlayerVisible)
{
    <div class="music-player">
        <!-- Thumbnail -->
        <div class="player-thumbnail">
            @if (isPlaying)
            {
                <span style="animation: spin 1s linear infinite;">🎵</span>
            }
            else
            {
                <span>🎵</span>
            }
        </div>

        <!-- Info -->
        <div class="player-info">
            <div class="player-title">@currentTrack?.Title</div>
            <div class="player-artist">@currentTrack?.Artist</div>
        </div>

        <!-- Controls -->
        <div class="player-controls">
            <!-- Time -->
            <div class="player-progress">
                <span class="time-text">@currentTime.ToString("mm\\:ss")</span>
                <div class="progress-bar" @onclick="(e) => SeekTrack(e)">
                    <div class="progress-fill" style="width: @(duration.TotalSeconds > 0 ? (currentTime.TotalSeconds / duration.TotalSeconds * 100) : 0)%"></div>
                </div>
                <span class="time-text">@duration.ToString("mm\\:ss")</span>
            </div>

            <!-- Play/Pause -->
            <button class="control-btn play" @onclick="TogglePlayPause">
                @if (isPlaying)
                {
                    <span>⏸️</span>
                }
                else
                {
                    <span>▶️</span>
                }
            </button>

            <!-- Previous -->
            <button class="control-btn" @onclick="PreviousTrack">⏮️</button>

            <!-- Next -->
            <button class="control-btn" @onclick="NextTrack">⏭️</button>

            <!-- Volume -->
            <div class="volume-control">
                <span style="color: #94a3b8; font-size: 0.9rem;">🔊</span>
                <div class="volume-slider" style="width: 60px;"></div>
            </div>

            <!-- Close -->
            <button class="close-player" @onclick="ClosePlayer">✕</button>
        </div>
    </div>

    <style>
    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }
    </style>
}

@code {
    private bool isPlayerVisible = false;
    private bool isPlaying = false;
    private TimeSpan currentTime = TimeSpan.Zero;
    private TimeSpan duration = new TimeSpan(0, 3, 45);

    private class Track
    {
        public string Title { get; set; }
        public string Artist { get; set; }
    }

    private Track currentTrack = new Track 
    { 
        Title = "درس ریاضی - فصل ۱",
        Artist = "آخرین نگهبان"
    };

    private Timer playerTimer;

    protected override void OnInitialized()
    {
        // For demo purposes
        isPlayerVisible = false;
    }

    public void PlayContent(string title, string artist, TimeSpan dur)
    {
        isPlayerVisible = true;
        currentTrack = new Track { Title = title, Artist = artist };
        duration = dur;
        isPlaying = true;
        StartPlayer();
    }

    private void StartPlayer()
    {
        playerTimer?.Dispose();
        playerTimer = new Timer(_ => 
        {
            if (isPlaying)
            {
                currentTime = currentTime.Add(TimeSpan.FromMilliseconds(100));
                if (currentTime >= duration)
                {
                    currentTime = TimeSpan.Zero;
                    isPlaying = false;
                }
                InvokeAsync(StateHasChanged);
            }
        }, null, 0, 100);
    }

    private void TogglePlayPause()
    {
        isPlaying = !isPlaying;
        if (isPlaying)
            StartPlayer();
    }

    private void PreviousTrack()
    {
        currentTime = TimeSpan.Zero;
    }

    private void NextTrack()
    {
        currentTime = TimeSpan.Zero;
    }

    private void SeekTrack(MouseEventArgs e)
    {
        // Seek to position
    }

    private void ClosePlayer()
    {
        isPlayerVisible = false;
        isPlaying = false;
        playerTimer?.Dispose();
    }

    void IDisposable.Dispose()
    {
        playerTimer?.Dispose();
    }
}
