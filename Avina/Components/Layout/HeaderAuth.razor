@rendermode InteractiveServer
@using Avina.Services
@inject AuthStateService AuthState
@inject IProfileAvatarService ProfileAvatarService
@implements IDisposable

@if (AuthState.IsLoggedIn && AuthState.CurrentUser != null)
{
    <a href="/profile" class="header-profile-link" title="پروفایل">
        <img src="@ProfileAvatarService.ResolveProfileImage(AuthState.CurrentUser.ProfileImage, AuthState.CurrentUser.Role)" alt="پروفایل" class="header-avatar">
    </a>
}
else
{
    <a href="/login" class="btn-auth-header">ثبت نام</a>
}

@code {
    protected override void OnInitialized()
    {
        AuthState.StateChanged += OnAuthChanged;
    }

    private async Task OnAuthChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthState.StateChanged -= OnAuthChanged;
    }
}
