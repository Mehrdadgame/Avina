@inherits LayoutComponentBase
@using Avina.Services
@inject NavigationManager Nav
@inject AuthStateService AuthState
@inject INotificationService NotificationService
@implements IDisposable

<HeadContent>
    <style>
        body, html, *:not(.material-symbols-outlined):not(.material-symbols-rounded):not(.material-symbols-sharp) {
            font-family: 'Vazirmatn', 'Segoe UI', Tahoma, sans-serif !important;
        }
        .material-symbols-outlined,
        .material-symbols-rounded,
        .material-symbols-sharp {
            font-family: 'Material Symbols Outlined' !important;
        }

        .guest-avatar {
            width: 44px; height: 44px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2e4770, #4248d4);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem; flex-shrink: 0;
        }

        .btn-auth-sidebar {
            display: block;
            width: 100%;
            padding: 0.65rem 1rem;
            border: none;
            border-radius: 0.75rem;
            background: linear-gradient(135deg, #4248d4, #9197ff);
            color: white;
            font-family: 'Vazirmatn', sans-serif;
            font-size: 0.875rem;
            font-weight: 700;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            transition: opacity 0.2s, transform 0.2s;
            margin-top: 0.5rem;
        }
        .btn-auth-sidebar:hover { opacity: 0.9; transform: translateY(-1px); }

        .btn-auth-header {
            padding: 0.45rem 1.1rem;
            border: none;
            border-radius: 0.625rem;
            background: linear-gradient(135deg, #4248d4, #9197ff);
            color: white;
            font-family: 'Vazirmatn', sans-serif;
            font-size: 0.8rem;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: opacity 0.2s;
            white-space: nowrap;
        }
        .btn-auth-header:hover { opacity: 0.9; }

        .btn-logout-sidebar {
            display: block;
            width: 100%;
            padding: 0.5rem 1rem;
            border: 1px solid rgba(255,180,171,0.3);
            border-radius: 0.75rem;
            background: transparent;
            color: #ffb4ab;
            font-family: 'Vazirmatn', sans-serif;
            font-size: 0.825rem;
            font-weight: 600;
            cursor: pointer;
            text-align: center;
            transition: background 0.2s;
            margin-top: 0.5rem;
        }
        .btn-logout-sidebar:hover { background: rgba(255,180,171,0.1); }

        .sidebar-coin-row {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.78rem;
            color: #ffb68c;
            font-weight: 700;
            margin-top: 0.25rem;
        }

        /* Welcome toast */
        .welcome-toast {
            position: fixed;
            top: 1.25rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            background: linear-gradient(135deg, #1e2d42, #2e4770);
            border: 1px solid rgba(170,199,255,0.3);
            border-radius: 1rem;
            padding: 0.85rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            animation: toastIn 0.45s cubic-bezier(0.34,1.56,0.64,1) both;
            white-space: nowrap;
            font-size: 0.9rem;
            color: #e0e2ec;
            font-weight: 600;
        }
        .welcome-toast.hiding { animation: toastOut 0.3s ease forwards; }
        @@keyframes toastIn {
            from { opacity: 0; transform: translateX(-50%) translateY(-20px) scale(0.95); }
            to   { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
        }
        @@keyframes toastOut {
            to { opacity: 0; transform: translateX(-50%) translateY(-20px) scale(0.95); }
        }
    </style>
</HeadContent>


<div class="app-layout">
    <!-- Sidebar Navigation -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <h1 class="logo">آخرین نگهبان</h1>
            <p class="logo-subtitle">Avina</p>
        </div>

        <nav class="sidebar-nav">
            <NavLink href="/" class="nav-item" Match="NavLinkMatch.All">
                <span class="nav-icon">🏠</span>
                <span class="nav-label">خانه</span>
            </NavLink>

            <NavLink href="/school" class="nav-item">
                <span class="nav-icon">📚</span>
                <span class="nav-label">مدرسه آنلاین</span>
            </NavLink>

            <NavLink href="/games" class="nav-item">
                <span class="nav-icon">🎮</span>
                <span class="nav-label">بازی‌های آموزشی</span>
            </NavLink>

            <NavLink href="/life-path" class="nav-item">
                <span class="nav-icon">🛤️</span>
                <span class="nav-label">مسیر من</span>
            </NavLink>

            <NavLink href="/store" class="nav-item">
                <span class="nav-icon">🛍️</span>
                <span class="nav-label">فروشگاه</span>
            </NavLink>
        </nav>

        <!-- Today's Challenge Button -->
        <a href="/school" class="btn-today-challenge">
            <span>⚡</span>
            <span>چالش امروز</span>
        </a>

        <div class="sidebar-footer">
            <SidebarAuth />
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-layout">
        <!-- Top Header -->
        <header class="top-header">
            <div class="header-left">
                <button class="btn-menu" id="toggleSidebar">☰</button>
                <div class="search-box">
                    <input type="text" placeholder="جستجو...">
                    <span class="search-icon">🔍</span>
                </div>
            </div>

            <div class="header-right">
                <a href="/upload" class="btn-upload" title="بارگذاری محتوا">
                    <span class="upload-icon">📤</span>
                    <span>اپلود</span>
                </a>
                <a href="/notifications" class="btn-notification @(unreadNotifications > 0 ? "has-unread" : "")" title="اعلان‌ها">
                    <span class="notification-icon">🔔</span>
                    @if (unreadNotifications > 0)
                    {
                        <span class="notification-badge">@FormatUnread(unreadNotifications)</span>
                    }
                </a>
                <HeaderAuth />
            </div>
        </header>

        <!-- Content Area -->
        <main class="main-content">
            @Body
        </main>
    </div>
</div>

<!-- Music Player -->
<MusicPlayer />

<div id="blazor-error-ui" data-nosnippet>
    خطای برنامه رخ داد.
    <a href="." class="reload">بارگذاری مجدد</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        AuthState.StateChanged += OnAuthStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshUnreadNotificationsAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private int unreadNotifications;

    private async Task OnAuthStateChanged()
    {
        await RefreshUnreadNotificationsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshUnreadNotificationsAsync();
            StateHasChanged();
        });
    }

    private async Task RefreshUnreadNotificationsAsync()
    {
        var user = AuthState.CurrentUser;
        if (user?.Id > 0)
        {
            unreadNotifications = await NotificationService.GetUnreadCountAsync(user.Id, user.Role);
        }
        else
        {
            unreadNotifications = 0;
        }
    }

    private static string FormatUnread(int count) => count > 99 ? "99+" : count.ToString();

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        AuthState.StateChanged -= OnAuthStateChanged;
    }
}
