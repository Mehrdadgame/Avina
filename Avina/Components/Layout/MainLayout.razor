@inherits LayoutComponentBase
@using Avina.Services
@using System.Text.Json
@inject AuthStateService AuthState
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>آخرین نگهبان</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css" rel="stylesheet" />
    <link rel="stylesheet" href="css/bootstrap.min.css" />
    <link rel="stylesheet" href="css/app-custom.css" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="css/school.css" />
    <link rel="stylesheet" href="css/games.css" />
    <link rel="stylesheet" href="css/store.css" />
    <link rel="stylesheet" href="css/profile.css" />
    <link rel="stylesheet" href="css/upload.css" />
    <link rel="stylesheet" href="css/home.css" />
    <link rel="stylesheet" href="css/responsive-components.css" />
    <style>
        body, html, * { font-family: 'Vazirmatn', 'Segoe UI', Tahoma, sans-serif !important; }

        .guest-avatar {
            width: 44px; height: 44px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2e4770, #4248d4);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem; flex-shrink: 0;
        }

        .btn-auth-sidebar {
            display: block;
            width: 100%;
            padding: 0.65rem 1rem;
            border: none;
            border-radius: 0.75rem;
            background: linear-gradient(135deg, #4248d4, #9197ff);
            color: white;
            font-family: 'Vazirmatn', sans-serif;
            font-size: 0.875rem;
            font-weight: 700;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            transition: opacity 0.2s, transform 0.2s;
            margin-top: 0.5rem;
        }
        .btn-auth-sidebar:hover { opacity: 0.9; transform: translateY(-1px); }

        .btn-auth-header {
            padding: 0.45rem 1.1rem;
            border: none;
            border-radius: 0.625rem;
            background: linear-gradient(135deg, #4248d4, #9197ff);
            color: white;
            font-family: 'Vazirmatn', sans-serif;
            font-size: 0.8rem;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: opacity 0.2s;
            white-space: nowrap;
        }
        .btn-auth-header:hover { opacity: 0.9; }

        .btn-logout-sidebar {
            display: block;
            width: 100%;
            padding: 0.5rem 1rem;
            border: 1px solid rgba(255,180,171,0.3);
            border-radius: 0.75rem;
            background: transparent;
            color: #ffb4ab;
            font-family: 'Vazirmatn', sans-serif;
            font-size: 0.825rem;
            font-weight: 600;
            cursor: pointer;
            text-align: center;
            transition: background 0.2s;
            margin-top: 0.5rem;
        }
        .btn-logout-sidebar:hover { background: rgba(255,180,171,0.1); }

        .sidebar-coin-row {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.78rem;
            color: #ffb68c;
            font-weight: 700;
            margin-top: 0.25rem;
        }

        /* Welcome toast */
        .welcome-toast {
            position: fixed;
            top: 1.25rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            background: linear-gradient(135deg, #1e2d42, #2e4770);
            border: 1px solid rgba(170,199,255,0.3);
            border-radius: 1rem;
            padding: 0.85rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            animation: toastIn 0.45s cubic-bezier(0.34,1.56,0.64,1) both;
            white-space: nowrap;
            font-size: 0.9rem;
            color: #e0e2ec;
            font-weight: 600;
        }
        .welcome-toast.hiding { animation: toastOut 0.3s ease forwards; }
        @keyframes toastIn {
            from { opacity: 0; transform: translateX(-50%) translateY(-20px) scale(0.95); }
            to   { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
        }
        @keyframes toastOut {
            to { opacity: 0; transform: translateX(-50%) translateY(-20px) scale(0.95); }
        }
    </style>
</head>
<body>
    <!-- Welcome toast -->
    @if (showToast)
    {
        <div class="welcome-toast @(hidingToast ? "hiding" : "")">
            <span style="font-size:1.2rem;">👋</span>
            <span>خوش اومدی، <strong style="color:#aac7ff;">@toastName</strong>!</span>
            <span style="font-size:0.8rem; color:#ffb68c;">🪙 +100 کوین</span>
        </div>
    }

    <div class="app-layout">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h1 class="logo">آخرین نگهبان</h1>
                <p class="logo-subtitle">Avina</p>
            </div>

            <nav class="sidebar-nav">
                <NavLink href="/" class="nav-item" Match="NavLinkMatch.All">
                    <span class="nav-icon">🏠</span>
                    <span class="nav-label">خانه</span>
                </NavLink>

                <NavLink href="/school" class="nav-item">
                    <span class="nav-icon">📚</span>
                    <span class="nav-label">مدرسه آنلاین</span>
                </NavLink>

                <NavLink href="/games" class="nav-item">
                    <span class="nav-icon">🎮</span>
                    <span class="nav-label">بازی‌های آموزشی</span>
                </NavLink>

                <NavLink href="/life-path" class="nav-item">
                    <span class="nav-icon">🛤️</span>
                    <span class="nav-label">مسیر من</span>
                </NavLink>

                <NavLink href="/store" class="nav-item">
                    <span class="nav-icon">🛍️</span>
                    <span class="nav-label">فروشگاه</span>
                </NavLink>
            </nav>

            <!-- Today's Challenge Button -->
            <a href="/school" class="btn-today-challenge">
                <span>⚡</span>
                <span>چالش امروز</span>
            </a>

            <div class="sidebar-footer">
                @if (AuthState.IsLoggedIn)
                {
                    <a href="/profile" class="user-profile">
                        <img src="@AuthState.CurrentUser!.ProfileImage" alt="@AuthState.CurrentUser.Name" class="user-avatar">
                        <div class="user-info">
                            <p class="user-name">@AuthState.CurrentUser.Name</p>
                            <p class="user-role">@AuthState.CurrentUser.Role</p>
                            <div class="sidebar-coin-row">
                                <span>🪙</span>
                                <span>@AuthState.CurrentUser.Coin.ToString("N0") کوین</span>
                            </div>
                        </div>
                    </a>
                    <button class="btn-logout-sidebar" @onclick="HandleLogout">خروج از حساب</button>
                }
                else
                {
                    <div class="user-profile" style="cursor:default;">
                        <div class="guest-avatar">👤</div>
                        <div class="user-info">
                            <p class="user-name">مهمان</p>
                            <p class="user-role">وارد نشده</p>
                        </div>
                    </div>
                    <a href="/login" class="btn-auth-sidebar">ثبت نام / ورود</a>
                }
            </div>
        </aside>

        <!-- Main Content -->
        <div class="main-layout">
            <!-- Top Header -->
            <header class="top-header">
                <div class="header-left">
                    <button class="btn-menu" id="toggleSidebar">☰</button>
                    <div class="search-box">
                        <input type="text" placeholder="جستجو...">
                        <span class="search-icon">🔍</span>
                    </div>
                </div>

                <div class="header-right">
                    <a href="/upload" class="btn-upload" title="بارگذاری محتوا">
                        <span class="upload-icon">📤</span>
                        <span>اپلود</span>
                    </a>
                    <button class="btn-notification">
                        <span class="notification-icon">🔔</span>
                        <span class="notification-badge">3</span>
                    </button>
                    @if (AuthState.IsLoggedIn)
                    {
                        <a href="/profile" class="header-profile-link" title="پروفایل">
                            <img src="@AuthState.CurrentUser!.ProfileImage" alt="پروفایل" class="header-avatar">
                        </a>
                    }
                    else
                    {
                        <a href="/login" class="btn-auth-header">ثبت نام</a>
                    }
                </div>
            </header>

            <!-- Content Area -->
            <main class="main-content">
                @Body
            </main>
        </div>
    </div>

    <!-- Music Player -->
    <MusicPlayer />

    <div id="blazor-error-ui" data-nosnippet>
        خطای برنامه رخ داد.
        <a href="." class="reload">بارگذاری مجدد</a>
        <span class="dismiss">🗙</span>
    </div>

    <script src="js/bootstrap.bundle.min.js"></script>
    <script src="js/app.js"></script>
</body>
</html>

@code {
    private const string StorageKey = "avina_user";

    // Toast state
    private bool showToast = false;
    private bool hidingToast = false;
    private string toastName = "";
    private bool _wasLoggedIn = false;

    protected override void OnInitialized()
    {
        AuthState.StateChanged += OnAuthChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !AuthState.IsLoggedIn)
        {
            await TryRestoreFromStorage();
        }
    }

    private async Task TryRestoreFromStorage()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("lsGet", StorageKey);
            if (!string.IsNullOrEmpty(json))
            {
                var user = JsonSerializer.Deserialize<UserCacheDto>(json);
                if (user != null)
                    AuthState.SetUser(user);
            }
        }
        catch { }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    private void OnAuthChanged()
    {
        // Show welcome toast when user logs in
        if (AuthState.IsLoggedIn && !_wasLoggedIn)
        {
            _wasLoggedIn = true;
            toastName = AuthState.CurrentUser?.Name ?? "";
            showToast = true;
            hidingToast = false;
            _ = DismissToastAsync();
        }
        else if (!AuthState.IsLoggedIn)
        {
            _wasLoggedIn = false;
            showToast = false;
        }
        InvokeAsync(StateHasChanged);
    }

    private async Task DismissToastAsync()
    {
        await Task.Delay(2800);
        hidingToast = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(350);
        showToast = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleLogout()
    {
        try { await JS.InvokeVoidAsync("lsRemove", StorageKey); } catch { }
        AuthState.Logout();
        Nav.NavigateTo("/");
    }

    public void Dispose()
    {
        AuthState.StateChanged -= OnAuthChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
