@inherits LayoutComponentBase

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>آخرین نگهبان</title>
    <link rel="stylesheet" href="lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="css/app-custom.css" />
    <link rel="stylesheet" href="css/school.css" />
    <link rel="stylesheet" href="css/games.css" />
    <link rel="stylesheet" href="css/store.css" />
    <link rel="stylesheet" href="css/profile.css" />
    <link rel="stylesheet" href="css/upload.css" />
    <link rel="stylesheet" href="css/home.css" />
    <link rel="stylesheet" href="css/responsive-components.css" />
</head>
<body>
    <div class="app-layout">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h1 class="logo">آخرین نگهبان</h1>
                <p class="logo-subtitle">Avina</p>
            </div>

            <nav class="sidebar-nav">
                <NavLink href="/" class="nav-item" Match="NavLinkMatch.All">
                    <span class="nav-icon">🏠</span>
                    <span class="nav-label">خانه</span>
                </NavLink>

                <NavLink href="/school" class="nav-item">
                    <span class="nav-icon">📚</span>
                    <span class="nav-label">مدرسه آنلاین</span>
                </NavLink>

                <NavLink href="/games" class="nav-item">
                    <span class="nav-icon">🎮</span>
                    <span class="nav-label">بازی‌های آموزشی</span>
                </NavLink>

                <NavLink href="/life-path" class="nav-item">
                    <span class="nav-icon">🛤️</span>
                    <span class="nav-label">مسیر من</span>
                </NavLink>

                <NavLink href="/store" class="nav-item">
                    <span class="nav-icon">🛍️</span>
                    <span class="nav-label">فروشگاه</span>
                </NavLink>

                <NavLink href="/profile" class="nav-item">
                    <span class="nav-icon">👤</span>
                    <span class="nav-label">پروفایل</span>
                </NavLink>

                <NavLink href="/pdf-reader" class="nav-item">
                    <span class="nav-icon">📖</span>
                    <span class="nav-label">خوانندگی PDF</span>
                </NavLink>
            </nav>

            <div class="sidebar-footer">
                <div class="user-profile">
                    <img src="images/profiles/user1.jpg" alt="کاربر" class="user-avatar">
                    <div class="user-info">
                        <p class="user-name">علی محمدی</p>
                        <p class="user-role">دانش‌آموز</p>
                    </div>
                </div>
                <button class="btn-logout">خروج</button>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="main-layout">
            <!-- Top Header -->
            <header class="top-header">
                <div class="header-left">
                    <button class="btn-menu" id="toggleSidebar">☰</button>
                    <div class="search-box">
                        <input type="text" placeholder="جستجو...">
                        <span class="search-icon">🔍</span>
                    </div>
                </div>

                <div class="header-right">
                    <a href="/upload" class="btn-upload" title="بارگذاری محتوا">
                        <span class="upload-icon">📤</span>
                    </a>
                    <button class="btn-notification">
                        <span class="notification-icon">🔔</span>
                        <span class="notification-badge">3</span>
                    </button>
                    <button class="btn-settings">⚙️</button>
                </div>
            </header>

            <!-- Content Area -->
            <main class="main-content">
                @Body
            </main>
        </div>
    </div>

    <!-- Music Player -->
    <MusicPlayer />

    <div id="blazor-error-ui" data-nosnippet>
        خطای برنامه رخ داد.
        <a href="." class="reload">بارگذاری مجدد</a>
        <span class="dismiss">🗙</span>
    </div>

    <script src="lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="js/app.js"></script>
</body>
</html>
